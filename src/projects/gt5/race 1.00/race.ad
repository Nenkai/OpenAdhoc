    function cb_init_item_tire_select(context, item, type)
    {
        var tire = type / 1000;
        var remain = type % 1000;

        if (tire < 3)
            var msg = "Normal" + (tire + 1);

        else if (tire < 6)
            var msg = "Sport" + (tire - 2);
            
        else
            var msg = "Racing" + (tire - 5);
            
        if (remain == 0)
            msg += "(Not available)";
            
        else if (remain < 100)
            msg += ("(remain:" + remain) + ")";
            
        item.label.text = msg;    
    }

    function selectTireDialog(context, title, init_num)
    {
        var root = context.getCurrentPage();
        var data = UIKitProject::SideSelectRoot::Data();

        data.title_ = title;
        data.translate_page_ = root;
        data.cb_init_item_ = cb_init_item_tire_select;
        data.enable_multi_ = false;
        data.initial_selected_indices_ = [init_num];
        data.frame_red_bring_ = false;
        data.candidates_ = [5];

        for (var i = 1; i < 9; i++)
        {
            var tire = i * 0x3E8;

            if (i == 4)
                var tire = tire + 0x64;

            else if (i != 3)
                var tire = tire + 0x0A;
                
            data.candidates_ += [tire];    
        }

        var result = UIKitProject::SideSelectRoot.open(context, data);

        if (result == nil || result.size == 0)
            return -1;

        return result[0];    
    }

    function cb_init_item_driver_select(context, item, driver)
    {
        var slot_id = main::RaceOperator.getAccountSlotID(0);
        var account_id = main::ORG.getAccountID(slot_id);

        if (main::RaceOperator.checkValidDriver(account_id, driver))
        {
            if (main::RaceOperator.isOnline())
            {
                var dp = main::RaceOperator.getAccountDriverParameter(account_id, driver);
                item.label.text = dp.display_name;
            }

            else
            {
                if (driver == 0)
                    item.label.text = "A-Spec";

                else
                    item.label.text = "B-Spec";                    
            }
        }

        else
            item.label.text = "INVALID";
    }

    function selectDriverDialog(context, min)
    {
        var root = context.getCurrentPage();
        var slot_id = main::RaceOperator.getAccountSlotID(0);
        var account_id = main::ORG.getAccountID(slot_id);
        var driver_list = [0];

        for (var i = 1; i < 4; i++)
        {
            if (main::RaceOperator.checkValidDriver(account_id, i))
                driver_list += [i];
        }

        if (driver_list.size < min)
            return nil;

        var idx = main::ORG.getRidingDriverIndex(slot_id);
        var data = UIKitProject::SideSelectRoot::Data();
        
        data.title_ = "DRIVER SELECT";
        data.translate_page_ = root;
        data.cb_init_item_ = cb_init_item_driver_select;
        data.enable_multi_ = false;
        data.initial_selected_indices_ = [idx];
        data.frame_red_bring_ = false;
        data.candidates_ = driver_list;

        var result = UIKitProject::SideSelectRoot.open(context, data);

        if (result == nil || result.size == 0)
            return -1;

        return result[0];    
    }

    function calcPitStopTime(context, ftire, rtire, petrol)
    {
        var f1_pit = false;
        var refuel_liter_per_sec = 100.0 / 50.0;

        if (f1_pit)
            var refuel_liter_per_sec = 10.0;

        var pit_stop_time = petrol / refuel_liter_per_sec;
        var ftire_change_time = (ftire != -1) * 5.0;
        var rtire_change_time = (rtire != -1) * 5.0;
        var tire_change_time = 0;
        
        if (f1_pit)
        {
            if (ftire_change_time > rtire_change_time)
                var tire_change_time = ftire_change_time;

            else
                var tire_change_time = rtire_change_time;    
        }

        else
        {
            var tire_change_time = ftire_change_time + rtire_change_time;

            if (ftire_change_time > 0 && rtire_change_time > 0)
                var tire_change_time = tire_change_time + 1.0;
        }

        if (tire_change_time > pit_stop_time)
            var pit_stop_time = tire_change_time;

        var pit_stop_time = pit_stop_time * 1000.0;
        
        return pit_stop_time;
    }

    function determinatePitWork(context, slot_id, on_edit, pit_strategy)
    {
        if (main::ORG.getEntryControlType(slot_id) != main::gtengine::ControlType::LOCAL)
        {
            DialogUtil::openConfirmDialog(context, DialogUtil::ERROR, "CANNOT_PITWORK");
            return;
        }

        if (on_edit)
        {
            PitStrategy.close(context);
            var event = RaceOperator.game_parameter.event;
            var constraint = event.constraint;
            var regulation = event.regulation;
            var invalid = gtengine::MGameParameter::INVALID_VALUE_INT;
            var data = PitRoot::Data();
            data.slot_id = slot_id;

            data.limit_tire_f = System::Math::min((constraint.limit_tire_f != invalid) ? constraint.limit_tire_f : 0x7FFFFFFF, 
            (regulation.limit_tire_f != invalid) ? regulation.limit_tire_f : 0x7FFFFFFF);

            if (data.limit_tire_f == 0x7FFFFFFF)
                data.limit_tire_f = invalid;

            data.need_tire_f = System::Math::max(constraint.need_tire_f, regulation.need_tire_f);
            
            data.limit_tire_r = System::Math::min((constraint.limit_tire_r != invalid) ? constraint.limit_tire_r : 0x7FFFFFFF, 
            (regulation.limit_tire_r != invalid) ? regulation.limit_tire_r : 0x7FFFFFFF)

            if (data.limit_tire_r == 0x7FFFFFFF)
                data.limit_tire_r = invalid;

            data.need_tire_r = System::Math::max(constraint.need_tire_r, regulation.need_tire_r);
            
            if (gSequenceCondition.is_online)
                data.invisible_driver = true;

            PitRoot.open(context, data, pit_strategy);    
        }

        else
            ORG.startVehiclePitWork(slot_id, pit_strategy);
    }

