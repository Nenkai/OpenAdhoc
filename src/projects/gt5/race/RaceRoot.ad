    method onStartSession(context)
    {
        ORG.setApplicationEndSessionSecond(gSequenceCondition.time_limit_second);

        if (PluginModule.defined("onStartSession"))
            PluginModule::onStartSession(context);

        removePauseMenu(context);
        createPauseMenu(context);
        changePauseState(context);
        ORG.noDispBackMirror(false);

        var current_rp = main::ORG.getCurrentRaceParameter();

        if (!gSequenceCondition.is_buffer_replay_mode && current_rp != nil && 
            current_rp.start_type == main::gtengine::StartType::GRID_FLYING &&
            current_rp.race_type == main::gtengine::RaceType::COMPETITION)
        {
            Info::WarningMessage.visible = true;
            Info::WarningMessage::FadeInterpolator.reverse = false;
            Info::WarningMessage::FadeInterpolator.restart();

            Info::WarningMessage::box::TextFace.text = context.translate(ROOT, "RaceProject::OnboardMeterRoot", "Penalty_Warning");
        }
        else
        {
            Info::WarningMessage.visible = false;
        }

        if (!gSequenceCondition.is_logger_mode)
        {
            if (gSequenceCondition.is_buffer_replay_mode && !gSequenceCondition.disable_replay_menu)
            {
                ORG.pauseHandleAvailable = false;
            }
            else
            {
                ORG.pauseAvailable = true;
                ORG.pauseRace = false;
            }
        }
        else
        {
            ROOT.replayStartByPauseState(context);
            sLoggerGotoHeadProcess = 1;
        }

        Foot.refresh(context);
    }

    method onEndSession(context)
    {
        context.flushEvent(function (e) 
        {
            if (e.isInstanceOf(menu::MScriptEvent))
                return true;
            else
                return false;
        });

        context.sync();

        if (PluginModule.defined("onEndSession"))
            PluginModule::onEndSession(context);
    }

    method replayStartByPauseState(context)
    {
        set_dt(1.0);
        pdistd::DelayThread(1000 * 50);
        set_dt(0.0);
    }

