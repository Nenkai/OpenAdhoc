            return EVENTRESULT_FILTER;

        var slot_id = RaceOperator.getPlayerSlot();
        var idx = main::ORG.getRidingDriverIndex(slot_id);
        
        var idx = (idx + 1) & 1;

        main::ORG.setRidingDriverIndex(slot_id, idx);
        closePauseMenu(context);
