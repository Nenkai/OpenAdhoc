    method onSectionTime(context, window, sectime, difftime, difflaps)
    {
        if (gSequenceCondition.gp.event.game_mode == main::gtengine::GameMode::DRIFT_ATTACK)
            return;

        if (PluginModule.defined("onSectionTime"))
        {
            PluginModule::onSectionTime(context, window, sectime, difftime, difflaps);
        }
        else
        {
            var WW = (window) ? OnboardMeterRoot::DivWork : OnboardMeterRoot;
            WW.RaceDisplayFace.setlaptime(sectime, difftime, window, 0);
            var W = WW.Info.SectionTime;

            if (sectime)
            {
                main::sound.play("sector");
                W.visible = false;
                W.ScalarInterpolator.restart();
                W.visible = true;
            }

            W = WW.Info.DiffTime;
            if (difflaps)
            {
                W.visible = false;
                W.ImageShape.visible = false;
                W.label.visible = true;
                var D = difflaps;

                if (difflaps < 0)
                    var D = -D;

                W.label.text = gSequenceCondition.diff_lap_texts[D > 1].build(difflaps.toInt());
                W.ScalarInterpolator.restart();
                W.visible = true;
            }
            else if (difftime)
            {
                W.visible = false;
                W.label.visible = false;
                W.ImageShape.visible = true;
                W.ScalarInterpolator.restart();
                W.visible = true;
            }
        }
    }

