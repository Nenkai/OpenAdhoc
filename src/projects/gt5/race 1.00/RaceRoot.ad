    function onTempRankingUpdate(context, car_rank, all_rank, eve_rank)
    {
        var msg = context.translate(ROOT, "TEMP_RANKING_MESSAGE") + " 
        ";

        if (eve_rank != 0)
        {
            msg += context.translate(ROOT, "TEMP_RANKING_EVENT").build(eve_rank);
        }

        else if (all_rank == 0)
        {
            msg += context.translate(ROOT, "TEMP_RANKING_CAR").build(car_rank);
        }

        else
        {
            msg += context.translate(ROOT, "TEMP_RANKING_ALL").build(car_rank, all_rank);
        }

        UIKitProject::MessengerRoot.putSystemChatMessage(context, gtengine::NoticeType::TemporaryRanking, 
        msg);
    }

