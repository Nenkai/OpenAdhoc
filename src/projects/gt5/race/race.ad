    function getRaceTypeKey(mdl, value)
    {
        var res = mdl.find_static(function (pair) {
            return pair[1] == value;
        })

        if (res.size <= 0)
            return "";

        return (mdl.name + "_") + res[0][0];    
    }

    function getRaceTypeName(context, mdl, value)
    {
        var key = getRaceTypeKey(mdl, value);
        return context.translate(PROJECT, "RaceTypeName", key);
    }

    function checkTrophyAfterRace(condition_satisfied)
    {
        var rp = ORG.getBackRaceParameter();

        if (!gSequenceCondition.isDemo() && rp.race_type == gtengine::RaceType::COMPETITION)
        {
            ORG.fetchRaceDisplay();
            var racers_max = ORG.racers_num_without_ghost;
            var order_list = ORG.getCarOrderList(false);

            if (racers_max >= 2 && order_list.size >= 2)
            {
                var player_slot = RaceOperator.getPlayerSlot();
                if (order_list.size > 1 && order_list[0] == player_slot)
                {
                    var report = ORG.getRaceDisplayReport(true, racers_max, 0, false);
                    var diff = report.total_time_diff[order_list[1]];
                    var diff2ds = diff.substr(0, diff.size - 1);

                    if (condition_satisfied && (diff == "+00.010" || diff == "+00,010" || diff2ds == "+00.00" || diff2ds == "+00,00"))
                        PDINetwork.unlockTrophyAsync(gtengine::TrophyType::BY_A_NARROW_MARGIN);

                    var ford = gtengine::MSpecDB::getCarCode("gt40_mk4_race_67");
                    var f330 = gtengine::MSpecDB::getCarCode("_330_p4_67");
                    var xj13 = gtengine::MSpecDB::getCarCode("xj13_66");

                    var is_ford = false;
                    var is_f330 = false;
                    var is_xj13 = false;
                    var cp = ORG.getEntriedCarParameter(player_slot);

                    if (cp != nil && condition_satisfied)
                    {
                        var code = cp.getCarCode();

                        if (code == ford || code == f330 || code == xj13)
                        {
                            foreach (var slot in order_list)
                            {
                                var cp = ORG.getEntriedCarParameter(slot);
                                if (cp != nil)
                                {
                                    var code = cp.getCarCode();

                                    if (code == ford)
                                        is_ford = true;

                                    if (code == f330)
                                        is_f330 = true;

                                    if (code == xj13)
                                        is_xj13 = true;    
                                }
                            }

                            if (is_ford && is_f330 && is_xj13)
                                PDINetwork.unlockTrophyAsync(gtengine::TrophyType::BATTLE_1967);
                        }
                    }
                }

                if (condition_satisfied && order_list.size > 1 && (player_slot == order_list[0] || player_slot == order_list[1]))
                {
                    var lanevo = gtengine::MSpecDB::getCarCode("lancer_evo10_gsr_premium_07");
                    var imp0 = gtengine::MSpecDB::getCarCode("impreza_sedan_wrx_sti_10");
                    var imp1 = gtengine::MSpecDB::getCarCode("impreza_wrx_sti_07");

                    var cp0 = ORG.getEntriedCarParameter(order_list[0]);
                    var cp1 = ORG.getEntriedCarParameter(order_list[1]);

                    if (cp0 != nil && cp1 != nil)
                    {
                        var car0 = cp0.getCarCode();
                        var car1 = cp1.getCarCode();

                        if ((car0 == lanevo && (car1 == imp0 || car1 == imp1)) || (car1 == lanevo && (car0 == imp0 || car0 == imp1)))
                            PDINetwork.unlockTrophyAsync(gtengine::TrophyType::BATTLE_RIVAL4WD);
                    }
                } 
            }
        }

        if (GAME_STATUS.user_profile.total_aspec_running_km + GAME_STATUS.user_profile.total_bspec_running_km >= 12718.0)
            PDINetwork.unlockTrophyAsync(gtengine::TrophyType::MILEAGE);

        if (!gSequenceCondition.isDemo() && !gSequenceCondition.enable_director_command && 
            (gSequenceCondition.game_mode == gtengine::GameMode::TIME_ATTACK || gSequenceCondition.game_mode == gtengine::GameMode::ONLINE_TIME_ATTACK) && 
            rp.course_code == gtengine::MSpecDB::getCourseCode("nurburgring"))
        {
            var player_slot = RaceOperator.getPlayerSlot();
            var cp = ORG.getEntriedCarParameter(player_slot);
            if (cp != nil && cp.rentacar)
            {
                if (cp.getCarLabel() == "gtr_07")
                {
                    |var tire_f, var tire_r| = cp.getTireCategories();

                    if (tire_f <= gtengine::PARTS_TIRE::SPORTS_HARD_A && tire_r <= gtengine::PARTS_TIRE::SPORTS_HARD_A)
                    {
                        var racers_max = ORG.racers_num_without_ghost;
                        var report = ORG.getRaceDisplayReport(true, racers_max, 0, false);
                        var time = report.fastest_lap_time_value[player_slot];

                        if (time <= 449030) // Time required for GT-R Lap (currently 449.030 seconds)
                            PDINetwork.unlockTrophyAsync(gtengine::TrophyType::GT_R_LAPTIME);
                    }
                }
            }
        }    
    }

    function setReplayLimit()
    {
        var size = pdistd::GetDiskFreeSize("/APP_DATA");
        var size = size.toLong() - main::REPLAY_MINIMUM_HDD_SPACE;

        if (size < 0)
            size = 0;
        else if (size > ((1024 * 1024) * 1024) * 3)
            size = ((1024 * 1024) * 1024) * 3;

        ORG.setReplayRecordableSize(size);    
    }

    function autoSetCamera()
    {
        if (ORG.isPreviewCameraInSpectator())
        {
            var racers_list = ORG.getCarOrderList();
            if (racers_list.size > 0)
            {
                ORG.setCameraTarget(0, racers_list[0]);
                return true;
            }
            else
                return false;
        }
        else
            return true;
    }

    static sLoadingProgress = pdistd::MProgress();
    static sLoadingWaitCancel = nil;
    static sOpenLoadProgress = false;

    function loadingWaitCancelCB(context)
    {
        sLoadingWaitCancel = true;
    }

    function onCancel_for_progress(context)
    {
        var handled = false;

        if (sOpenLoadProgress)
        {
            main::sound.play("cancel");
            sLoadingWaitCancel = true;
            var handled = true;
        }

        return handled;
    }

    function loadinWaitProgress(context)
    {
        var max_racers = ORG.getCurrentRaceParameter().racers_max;

        if (max_racers == 0)
        {
            sLoadingProgress.value = 1.0;
            context.leaveEventLoop();
            return;
        }

        var now_racers;
        do
        {
            var stm = ORG.getCourseStreamProgress() * 0.5;
            now_racers = ORG.getLoadedCarCount();

            sLoadingProgress.value = stm + ((now_racers.toFloat() / max_racers.toFloat()) * 0.5);

            if (ORG.inCourseAllEntries() == false)
                now_racers = 0;

            if (ORG.inCourse() == false)
                now_racers = 0;

            if (ORG.isRestartSequence() == true)
                now_racers = 0;

            if (ORG.isFinishedFirstLoad() == false)
                now_racers = 0;

            if (ORG.inSession() == false)
                now_racers = 0;

            Thread::Sleep(0.1);
        } while (now_racers < max_racers && sLoadingWaitCancel == false)

        context.leaveEventLoop();
    }

    function openVehicleLoadingProgress(context, shrink)
    {
        if (sOpenLoadProgress == true)
            return false;

        main::sound.play("ok");
        var prev_index = RaceMenuUtil::getFocusIndex();
        
        if (shrink != nil && shrink)
            RaceMenuUtil::shrinkAction(context);

        CursorUtil::setCursor(context, "wait");
        sOpenLoadProgress = true;
        sLoadingProgress.value = 0.0;
        sLoadingWaitCancel = false;

        var root = context.getCurrentPage();
        root.setFocus(nil);
        RaceMenuUtil::disableFocus(context);

        var msg = context.translate(root, "QuickMenu", "NOW_LOADING");
        var thread = Thread(loadinWaitProgress, context);
        thread.start();
        context.enterEventLoop();
        thread.terminate();

        var result = !sLoadingWaitCancel;
        sOpenLoadProgress = false;

        if (result == false)
            RaceMenuUtil::resetCloseAction(context, true);

        RaceMenuUtil::enableFocus(context);
        RaceMenuUtil::setFocus(context, prev_index);
        CursorUtil::setCursor(context, "cursor_chrome");

        return result;
    }

    static sWetInfoEnable = false;
    static sWetInfoCourseCode = nil;

    function checkWetInfoVisibleCondition()
    {
        var course = getCurrentCourse();

        if (sWetInfoCourseCode == nil || sWetInfoCourseCode != course)
        {
            var courseInfo = CourseData::getCourseInfo(course);
            sWetInfoEnable = courseInfo.rain_situation && courseInfo.celsius_base0 >= 0;
            sWetInfoCourseCode = course;
        }
    }

    function setWetInfoVisibleText(context, wet_old, wlist)
    {
        if (sWetInfoEnable)
        {
            var report = ORG.getRaceDisplayReport(false, 1, 0);
            var wet = ((report.water_retantion[1] * 100.0) + 0.5).toInt();

            if (wet_old != wet)
            {
                var str = context.translate(PROJECT, "Unit", "PERCENT").build(wet);
                foreach (var ww in wlist)
                {
                    ww.TextFace.text = str;
                    ww.visible = true;
                }
            }

            return wet;
        }
        else
        {
            foreach (var ww in wlist)
                ww.visible = false;

            return -1;
        }
    }

    static sWetInfoWidget = nil;
    static sWetInfoCurrentValue;
    static sWetInfoUpdateRunning;
    static sWetInfoThread;

    function _updateWetInfo()
    {
        if (ORG.inSession())
        {
            var report = ORG.getRaceDisplayReport(false, 1, 0);
            var retention = ((report.water_retantion[1] * 100.0) + 0.4).toInt();

            if (sWetInfoCurrentValue == nil || retention != sWetInfoCurrentValue)
            {
                sWetInfoWidget.TextFace.text = menu::TranslateRtext(PROJECT, "Unit", "PERCENT").build(retention);
                sWetInfoCurrentValue = retention;
                sWetInfoWidget.visible = true;
            }
        }
        else
        {
            sWetInfoWidget.visible = false;
            sWetInfoCurrentValue = nil;
        }
    }

    function _updateWetInfoEntry()
    {
        sWetInfoUpdateRunning = true;

        while (sWetInfoUpdateRunning)
        {
            _updateWetInfo();
            Thread::Sleep(5);
        }
    }

    function updateWetInfo(context)
    {
        if (sWetInfoUpdateRunning != nil && sWetInfoUpdateRunning && sWetInfoThread != nil)
            sWetInfoThread.wakeup();
    }

    function beginUpdateWetInfo(context, widget, courseInfo)
    {
        if (courseInfo == nil)
            courseInfo = CourseData::getCourseInfo(getCurrentCourse());

        sWetInfoCourseCode = courseInfo.code;

        if (!courseInfo.rain_situation || courseInfo.celsius_base0 < 0)
        {
            sWetInfoEnable = false;
            return;
        }

        sWetInfoEnable = true;
        sWetInfoWidget = widget;
        sWetInfoThread = Thread(_updateWetInfoEntry);
        sWetInfoThread.start();
    }

    function endUpdateWetInfo(context)
    {
        if (sWetInfoUpdateRunning == nil || !sWetInfoUpdateRunning)
            return;

        sWetInfoUpdateRunning = false;

        if (sWetInfoWidget != nil)
        {
            sWetInfoWidget.visible = false;
            sWetInfoWidget = nil;
        }
    }
}