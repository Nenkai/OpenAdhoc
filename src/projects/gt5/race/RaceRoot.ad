    method onActivateDetectToAppearMenu(context)
    {
        OnboardMeterRoot.disappearPanel();
        activateFoot(context);
        ROOT.endLeaveDetect(context);
    }

    method startLeaveDetect(context)
    {
        LeaveDetectUtil::begin(context, 4, self, self.onLeaveDetectToHideMenu, self.onActivateDetectToAppearMenu, true);
    }

    method endLeaveDetect(context)
    {
        LeaveDetectUtil::end(context);
    }

    method isLeaveDetecting()
    {
        return LeaveDetectUtil::isWorking();
    }

