    function selectAmountOfPetrol(context, min, max, step)
    {
        var gas = UIKitProject::SliderMenuRoot.open(context, 
        "Amount of petrol", RaceRoot.w / 2, RaceRoot.h / 2, 
        min, max, (max + min) / 2, step, "L", "", onPetrolChangeCB);

        if (gas == nil)
            return -1;

        return gas;    
