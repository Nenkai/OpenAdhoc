    method set_dt(dt)
    {
        if (gSequenceCondition.is_buffer_replay_mode)
            ORG.pauseRace = dt == 0.0;

        else
            ORG.pauseRace = dt == 0.0;    
    }

    method onSpectatorStopTime(context)
    {
        main::sound.play("ok");
        ORG.disableSoundingRace();
        set_dt(0.0);

        return EVENTRESULT_FILTER;
    }

    method onSpectatorStartTime(context)
    {
        main::sound.play("ok");
        ORG.enableSoundingRace();

        if (!ORG.getRaceSound().start)
            ORG.getRaceSound().start = true;

        set_dt(1.0);
        return EVENTRESULT_FILTER;    
    }

    method onSpectatorSlowTime(context)
    {
        main::sound.play("ok");
        set_dt(0.25);
        return EVENTRESULT_FILTER;
    }

    method onSpectatorFastTime(context)
    {
        main::sound.play("ok");
        set_dt(4.0);

        return EVENTRESULT_FILTER;
    }

    method onSpectatorPause(context)
    {
        main::sound.play("ok");

        if (gSequenceCondition.is_buffer_replay_mode)
        {
            if (!ORG.pauseRace)
                set_dt(0.0);

            else
                set_dt(1.0);    
        }

        else
        {
            ORG.pauseRace = !ORG.pauseRace;
        }

        return EVENTRESULT_FILTER;
    }

    method onLoggerGotoHead(context)
    {
        if (!RaceTimeAttackProject::DataLoggerRoot.isActive())
            return EVENTRESULT_FILTER;

        ORG.pauseRace = false;
        pdistd::DelayThread(0x3E8 * 0x32);
        onTimeLimit(context, 0, 0);
        
        return EVENTRESULT_FILTER;
    }

    method onLoadReferenceData(context)
    {
        ORG.disableSoundingRace();
        var prev_pause = ORG.pauseRace;
        set_dt(0.0);

        var rp = main::ORG.getCurrentRaceParameter();
        LeaveDetectUtil::suspend(context);
        var file_list = ReplayFileUtil::getListGhostOneLapForDataLogger(rp.course_code);
        var result = nil;

        if (file_list.size == 0)
        {
            DialogUtil::openConfirmDialog(context, DialogUtil::ERROR, 
            context.translate(ROOT, "REFERENCE_DATA_IS_NOT_AVAILABLE"));
        }

        else
        {
            var result = UIKitProject::FileSelectRoot.open(context, 
            UIKitProject::FileSelectRoot::REPLAY_LOAD_GHOST_ONE_LAP_FOR_DATALOGGER);
        }

        if (result != nil && result)
            RaceTimeAttackProject::DataLoggerRoot.setReferenceData();

        LeaveDetectUtil::resume(context);
        
        if (prev_pause)
            set_dt(0.0);

        else
            set_dt(1.0);
            ORG.enableSoundingRace();
            
        return EVENTRESULT_FILTER;    
    }

    method onDataLoggerOption(context)
    {
        if (!RaceTimeAttackProject::DataLoggerRoot.isActive())
            return EVENTRESULT_FILTER;

        ORG.pauseHandleAvailable = false;
        ORG.disableSoundingRace();
        var prev_pause = ORG.pauseRace;
        set_dt(0.0);
        
        var data = RaceTimeAttackProject::DataLoggerRoot.getDisplayOption(context);
        var data = RaceTimeAttackProject::DataLoggerOptionRoot.open(context, data);

        if (data != nil)
            RaceTimeAttackProject::DataLoggerRoot.setDisplayOption(context, data);

        if (prev_pause)
            set_dt(0.0);
            
        else
            set_dt(1.0);
            
        ORG.enableSoundingRace();
        ORG.pauseHandleAvailable = true;
        return EVENTRESULT_FILTER;    
    }

    method getCurrentCrouseName(context)
    {
        var crs_code = main::ORG.getCurrentCourseCode();
        var crs_label = main::gtengine::MSpecDB::getCourseLabel(main::ORG.getCurrentCourseCode());
        var course_name_i18n = context.translate(ROOT, "CourseNameI18n", crs_label).upcase();
        var is_reverse = CourseData::isReverse(crs_code);

        if (is_reverse)
        {
            var reverse = context.translate(ROOT, "CourseData", "direction_reverse_not_asian_language").upcase();
            var course_name_i18n = "%{course_name_i18n} / %{reverse}";
        }

        return course_name_i18n;
    }

    static sPrevHeadVisible = false;
    static sPrevIsPitIn = false;

    method onPhotoMode(context)
    {
        sPrevIsPitIn = false;

        if (ORG.isTargetCaPitIn())
        {
            sPrevIsPitIn = true;
            var camnum = ORG.getTargetCarDistributeCameraNum();

            if (camnum <= 0)
            {
                main::sound.play("disable");
                return EVENTRESULT_FILTER;
            }
        }

        main::sound.play("ok");
        SequenceUtil::setupTransition(context, CursorProject::ColorTransition);
        context.pageOutRootTransition();
        context.syncOutRootTransition();

        set_dt(0.0);
        ORG.setUpdatePauseAsyncIndex(true);
        LeaveDetectUtil::suspend(context);
        deactivateFoot(context);

        ROOT::LTBase.visible = false;
        Foot.visible = false;
        sPrevHeadVisible = Head.visible;
        Head.visible = false;

        var order_list = ORG.getCarOrderList(false);
        var standard_slot_list = [];

        foreach (var slot_id in order_list)
        {
            var cp = ORG.getEntriedCarParameter(slot_id);

            if (cp != nil)
            {
                if (gtengine::MSpecDB::isStandardModel(cp.getCarCode()))
                    standard_slot_list.push(slot_id);
            }
        }

        main::ORG.setCamera(main::gtengine::CameraType::WALK);
        main::ORG.setCameraInputEnable(true);
        main::ORG.getRaceSound().start = false;
        var crs_label = main::gtengine::MSpecDB::getCourseLabel(main::ORG.getCurrentCourseCode());

        var camera_target = ORG.getCameraTarget(0);
        var cp = ORG.getEntriedCarParameter(camera_target);

        PhotoProject::PhotoTravelRoot.open(context, nil, true, 
        onPhotoModeFinishCB, standard_slot_list, crs_label, cp, sPrevIsPitIn);
        context.sync(0.1);
        context.pageInRootTransition();

        return EVENTRESULT_FILTER;
    }

    method onPhotoModeFinishCB(context)
    {
        SequenceUtil::setupTransition(context, CursorProject::ColorTransition);
        context.pageOutRootTransition();
        context.syncOutRootTransition();

        context.cursor_visible = true;
        main::ORG.setCamera(main::gtengine::CameraType::SPECTATOR);
        main::ORG.setCameraInputEnable(false);

        Head.visible = sPrevHeadVisible;
        Foot.visible = true;
        ROOT::LTBase.visible = true;
        activateFoot(context);

        if (Foot::Button::ViewFull.active)
        {
            Foot.setFullView(context);
        }

        else if (Foot::Button::ViewLT.active)
        {
            Foot.setLiveTimingView(context);
        }

        else
        {
            Foot.setDataLoggerView(context);
        }

        LeaveDetectUtil::resume(context);
        appearPhoto(context);
        context.pageInRootTransition();
        ORG.pauseRace = true;
    }

    method execCommand(str, que)
    {
        main::ORG.execCommand(str);
    }

    method onEasyPhoto(context)
    {
        set_dt(0.0);
        LeaveDetectUtil::suspend(context);
        SequenceUtil::setupTransition(context, CursorProject::GTLogoTransition);

        context.pageOutRootTransition();
        context.syncOutRootTransition();
        LeaveDetectUtil::suspend(context);

        deactivateFoot(context);
        Foot.current_view.visible = false;
        Foot.visible = false;
        sPrevHeadVisible = Head.visible;
        Head.visible = false;

        if (ORG.is_camera_subjective)
        {
            execCommand("setCaptureCameraFollowType true false");
        }

        else
        {
            var state = context.getUpdateContext().getPadButtonState(0);

            if (state & 0x100)
                execCommand("setCaptureCameraFollowType false fasel"); //fasel lol

            else
                execCommand("setCaptureCameraFollowType true true");    
        }

        execCommand("setScreenShotImageFormat 0");
        execCommand("setScreenShotSubFrame 128");

        var size_cmd = "setScreenShotDivision %d %d".format(1, 1);
        execCommand(size_cmd);
        context.sync();

        var photo_desc = "EasyPhoto";
        var user_name = main::Grim2.getLoginUserId();

        var course_label = main::gtengine::MSpecDB::getCourseLabel(main::ORG.getCurrentCourseCode());
        var camera_target = ORG.getCameraTarget(0);
        var cp = ORG.getEntriedCarParameter(camera_target);
        var car_code = cp.getCarCode();
        var car_label = main::gtengine::MSpecDB::getCarLabel(car_code);

        if (course_label == "akasaka" || course_label == "r_akasaka")
        {
            if (CheckUnlockTrophyHondaAtHondaSingle(
            main::gtengine::MSpecDB::getTunerCode(car_code), camera_target))
            {
                PDINetwork.unlockTrophyAsync(gtengine::TrophyType::TAKE_A_PHOTO_OF_HONDA_AT_HONDA);
            }
        }

        execCommand("takePhoto %d %d %s %s %s %s %d".format(
        1920, 1080, photo_desc, user_name, course_label, car_label, 1));

        context.sync(0.1);

        while (main::ORG.isUnderPhotoRendering())
        {
            
        } 

        context.pageInRootTransition();
        isPhotoPreview = true;

        while (main::ORG.isUnderPhotoEncoding())
        {
            
        }

        AfterShootingHelp::ScalarInterpolator.reverse = false;
        AfterShootingHelp::ScalarInterpolator.restart();
        AfterShootingHelp::Pane::ScalarInterpolator.reverse = false;
        AfterShootingHelp::Pane::ScalarInterpolator.restart();
        AfterShootingHelp.visible = true;

        return EVENTRESULT_FILTER;
    }

    method backFromPreivew(context)
    {
        SequenceUtil::setupTransition(context, CursorProject::ColorTransition);
        context.pageOutRootTransition();
        context.syncOutRootTransition();

        AfterShootingHelp::Pane::ScalarInterpolator.reverse = true;
        AfterShootingHelp::Pane::ScalarInterpolator.start();
        AfterShootingHelp.visible = false;
        Head.visible = sPrevHeadVisible;
        Foot.visible = true;
        Foot.current_view.visible = true;

        activateFoot(context);
        LeaveDetectUtil::resume(context);
        main::ORG.exitPhotoPreview();
        context.pageInRootTransition();
    }

    function every_true_func(context)
    {
        return EVENTRESULT_STOP;
    }

    method savePhotoFile(context)
    {
        var data = PhotoFileUtil::Data();
        var st = main::pdistd::GetFileStatus(main::ORG.photo_org_path);
        var st_t = main::pdistd::GetFileStatus(main::ORG.photo_thumb_path);

        if (st["result"] == 0 && st_t["result"] == 0)
        {
            data.filesize = st["size"];
            data.filesize_t = st_t["size"];
            data.id = 0;

            data.genre = PhotoFileUtil::GENRE::PHOTO_RACE;

            var course_info = CourseData::getCourseInfo(main::ORG.getCurrentCourseCode());
            data.title = course_info.name;
            data.subtitle = "";
            data.description = "";

            data.width = 1920;
            data.height = 1080;
            data.orientation = 1;

            var camera_target = ORG.getCameraTarget(0);
            var cp = ORG.getEntriedCarParameter(camera_target);
            data.car_label = main::gtengine::MSpecDB::getCarLabel(cp.getCarCode());

            data.snapshot_filename = "";
            data.favorite = 0;
            data.online = 0;
            data.vertical = 0;
            data.is_3d = 0;

            data.car_position_left = -1;
            data.car_position_top = -1;
            data.car_position_right = -1;
            data.car_position_bottom = -1;

            data.online_id = main::Grim2.getLoginUserId();
            PhotoFileUtil::save(context, main::ORG.photo_org_path, main::ORG.photo_thumb_path, data);

            DialogUtil::openConfirmExecDialog(context, nil, 
            context.translate(ROOT, "PhotoMode", "SAVE_DONE"), nil, nil, 
            every_true_func, nil, 1.0, true);
        }
    }

    method onSpectatorExit(context)
    {
        if (PluginModule.defined("onSpectatorExit"))
            PluginModule::onSpectatorExit(context);

        else
            quit(context);
            
        return EVENTRESULT_FILTER;    
    }

    method onBeginerAdvice(context, id)
    {
        if (gSequenceCondition.is_buffer_replay_mode)
            return;

        var message = [
            "BSPEC_ADVICE0",
            "BSPEC_ADVICE1",
            "BSPEC_ADVICE2",
            "BSPEC_ADVICE3",
            "BSPEC_ADVICE4",
            "BSPEC_ADVICE5"
        ];
        
        Foot::MessageWindow::VBox::TextFace.text = context.translate(ROOT, message[id]);
        Foot::MessageWindow::FadeActor.restart();
        Foot::MessageWindow.visible = true;
    }

    method createPauseMenu(context)
    {
        var icons = [];

        if (!gSequenceCondition.isASpecPlaying())
        {
            RaceMenuUtil::create(context, ROOT, Template::PlayMenu, nil, "QuickMenu", nil, nil, true);
        }

        else
        {
            icons.push(RaceMenuUtil::Icon("CONTINUE", "icon_Q_continue.dds", onContinue));

            if (gSequenceCondition.is_online)
            {
                var online_room = RaceOperator.game_parameter.online_room;

                if (ORG.isFreeRun() && gtengine::MGameParameter::CanRaceInTrackDayType(online_room.trackday_mode))
                {
                    icons.push(RaceMenuUtil::Icon("TORACE", "icon_Q_singleRace.dds", onPrepareRaceRequest));
                }
            }

            if (gSequenceCondition.enable_restart)
            {
                icons.push(RaceMenuUtil::Icon("RESTART", "icon_Q_restart.dds", onRestart));
            }

            if (gSequenceCondition.enable_driver_change)
            {
                icons.push(RaceMenuUtil::Icon("DRIVER_CHANGE(DEBUG)", "icon_Q_driver_change.dds", onDriverChange));
            }

            if (gSequenceCondition.game_mode != gtengine::GameMode::SPLIT_BATTLE 
            && gSequenceCondition.game_mode != gtengine::GameMode::SPLIT_ONLINE_BATTLE 
            && gSequenceCondition.game_mode != gtengine::GameMode::MULTIMONITOR_CLIENT)
            {
                icons.push(RaceMenuUtil::Icon("QUICKOPTION", "icon_Q_debug.dds", onQuickOptionMenu));
            }

            icons.push(RaceMenuUtil::Icon("EXIT", "icon_Q_exit.dds", onExit));

            RaceMenuUtil::create(context, ROOT, Template::RaceMenu, icons, "QuickMenu", nil, nil, true);
        }
    }

    method removePauseMenu(context)
    {
        RaceMenuUtil::remove(context);
    }

