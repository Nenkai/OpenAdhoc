




module ROOT
{
    hidden.visible = false;
    static sActivatedMenu = false;
    static sActivatedMenuForRealEvent = false;

    attribute sInstanceWidget;
    attribute sParentWidget;
    attribute sPrevFrameInterval;

    method isActive(context)
    {
        return self.sInstanceWidget != nil;
    }

    method initialize(context, parent_widget, initial_out, repeat)
    {
        if (self.sInstanceWidget != nil)
            return;
        
        context.loadGpb("%{main::PROJECT_ROOT_DIR}/race", "FullViewRoot");

        RaceRoot::Foot::Button::ViewDispOff.visible = true;

        self.sPrevFrameInterval = menu::FrameInterval;
        menu::FrameInterval = 2;

        self.sParentWidget = parent_widget;
        self.sInstanceWidget = View.doCopy();
        self.sInstanceWidget.MapChatPane.set_visible();
        self.sParentWidget.appendChild(context, self.sInstanceWidget);

        self.sInstanceWidget.initialize(context);
        self.sInstanceWidget.refresh(context, true);

        if (repeat != nil && repeat)
            initial_out = !sActivatedMenu;

        if (initial_out != nil && initial_out)
        {
            RaceRoot.startLeaveDetect(context);
            LeaveDetectUtil::reset(context);
            self.sInstanceWidget.deactivateMenu(context, true);
        }
        else
            self.sInstanceWidget.activateMenu(context, true);

        self.initializeTick(context);
    }

    method finalize(context)
    {
        if (self.sInstanceWidget != nil)
        {
            {
                self.finalizeTick(context);
                self.sInstanceWidget.finalize(context);
                self.sParentWidget.removeChild(context, self.sInstanceWidget);

                self.sParentWidget = nil;
                self.sInstanceWidget = nil;

                menu::FrameInterval = self.sPrevFrameInterval;
                self.sPrevFrameInterval = nil;
            }

            RaceRoot::Foot::Button::ViewDispOff.visible = false;
            context.unloadGpb("%{main::PROJECT_ROOT_DIR}/race", "FullViewRoot");
        }
    }

    method refresh(context)
    {
        if (self.sInstanceWidget != nil)
            self.sInstanceWidget.refresh(context, true);       
    }

    method onTick(context)
    {
        if (!sActivatedMenu)
            return;

        if (self.sInstanceWidget != nil)
            self.sInstanceWidget.refresh(context, false);        
    }

    attribute sWatcher;

    method initializeTick(context)
    {
        self.sWatcher = WatcherUtil::Create(context, onTick, 30);
    }

    method finalizeTick(context)
    {
        if (self.sWatcher != nil)
        {
            WatcherUtil::Delete(self.sWatcher);
            self.sWatcher = nil;
        }
    }

    module View
    {
        attribute base_rank_list;

        method initialize(context)
        {
            if (gSequenceCondition.enable_director_command && !gSequenceCondition.is_buffer_replay_mode)
            {
                RenderControl.visible = true;
                RenderControl.begin(ORG);
            }
            else
            {
                RenderControl.visible = false;
            }

            if (gSequenceCondition.is_online && !gSequenceCondition.is_buffer_replay_mode)
            {
                self.MapPane.visible = false;
                self.MapChatPane.visible = true;
                self.MapChatPane.initialize(context);
            }
            else
            {
                self.MapPane.visible = true;
                self.MapChatPane.visible = false;
                self.MapPane.initialize(context);
            }

            self.DriverName.visible = false;
            DriverNameInitialize(context, self.DriverName);

            self.RacerPane.initialize(context);
            self.RDP.begin4bspec(ORG, Parette, CarPane, RaceRoot::Info, DriverName);
            self.Parette::speed::Img_unit.image_path = OnboardMeterRoot::UnitImagePath();
        }

        method finalize(context)
        {
            if (gSequenceCondition.is_online && !gSequenceCondition.is_buffer_replay_mode)
                self.MapChatPane.finalize(context);
            else
                self.MapPane.finalize(context);

            self.RacerPane.finalize(context);
            self.RDP.end();

            if (RenderControl.visible)
                RenderControl.end(ORG);

            DriverNameFinalize(context);
        }

        method refresh(context, warp)
        {
            var res = autoSetCamera();
            CarPane.visible = res;
            Parette.visible = res;

            if (ORG.is_camera_subjective && !sActivatedMenu && gSequenceCondition.is_buffer_replay_mode)
                ORG.disp_meter = true;
            else
                ORG.disp_meter = false;

            ORG.fetchRaceDisplay();
            var entry_max = ORG.getCurrentRaceParameter().entry_max;
            var report = ORG.getRaceDisplayReport(false);
            var racers_list = ORG.getCarOrderList();
            var move_index_list;

            if (warp)
            {
                self.base_rank_list = racers_list;
                var move_index_list = racers_list;;
            }
            else
            {
                |var new_base_rank_list, var move_index_list| = pdistd::TraceRankList(self.base_rank_list, racers_list, 16);
                self.base_rank_list = new_base_rank_list;
            }

            menu::LiveTimingUtil::RefreshCarPane(self.CarPane, ORG);
            self.RacerPane.refresh(context, entry_max, report, racers_list, warp, move_index_list);

            setWetInfoVisibleText(context, -1, [self.MapChatPane::Map::WetInfo, self.MapPane::WetInfo]);
        }

        method DriverNameInitialize(context, DD)
        {
            for (var i = 0; i < 16; i++)
            {
                var item2 = hidden::NameItem.doCopy();
                DD.appendChild(context, item2);
            }
        }

        method DriverNameFinalize(context)
        {
            self.DriverName.clearChildren(context);
        }

        method DriverNameRefresh(context, warp)
        {

        }

        method activateMenu(context, warp)
        {
            sActivatedMenu = true;

            foreach (var sip in [
                RacerPane::ScalarInterpolator,
                MapPane::ScalarInterpolator,
                MapChatPane::ScalarInterpolator,
                Parette::ScalarInterpolator,
                CarPane::ScalarInterpolator
            ])
            {
                sip.reverse = false;

                if (warp != nil && warp)
                    sip.warp();
                else
                    sip.start();
            }

            for (var i = 0; i < RacerPane.fixed_items.size; ++i)
                RacerPane.fixed_items[i].can_focus = true;

            RacerPane.Head.UserID.can_focus = true;
            RacerPane.Head.Car.can_focus = true;
            ORG.disp_meter = false;
            OnboardMeterRoot.visible = false;
            OnboardMeterRoot::Fader.restart();

            if (warp == nil || !warp)
                MapChatPane.Chat.activate(context);
        }

        method deactivateMenu(context, warp)
        {
            if (warp == nil || !warp)
                MapChatPane.Chat.deactivate(context);

            sActivatedMenu = false;

            foreach (var sip in [
                RacerPane::ScalarInterpolator,
                MapPane::ScalarInterpolator,
                MapChatPane::ScalarInterpolator,
                Parette::ScalarInterpolator,
                CarPane::ScalarInterpolator
            ])
            {
                sip.reverse = true;

                if (warp != nil && warp)
                    sip.warp();
                else
                    sip.start();
            }

            for (var i = 0; i < RacerPane.fixed_items.size; ++i)
                RacerPane.fixed_items[i].can_focus = false;

            RacerPane.Head.UserID.can_focus = false;
            RacerPane.Head.Car.can_focus = false;

            if (ORG.is_camera_subjective && gSequenceCondition.is_buffer_replay_mode)
                ORG.disp_meter = true;

            OnboardMeterRoot.visible = true;
        }

        method activateMenuForRealEvent(context, warp)
        {
            sActivatedMenuForRealEvent = true;

            foreach (var sip in [
                MapPane::ScalarInterpolator,
                MapChatPane::ScalarInterpolator,
                Parette::ScalarInterpolator,
                CarPane::ScalarInterpolator
            ])
            {
                sip.reverse = false;

                if (warp != nil && warp)
                    sip.warp();
                else
                    sip.start();
            }

            for (var i = 0; i < RacerPane.fixed_items.size; ++i)
                RacerPane.fixed_items[i].can_focus = true;

            RacerPane.Head.UserID.can_focus = true;
            RacerPane.Head.Car.can_focus = true;
            ORG.disp_meter = false;
            OnboardMeterRoot.visible = false;
            OnboardMeterRoot::Fader.restart();

            if (warp == nil || !warp)
                MapChatPane.Chat.activate(context);
        }

        method deactivateMenuForRealEvent(context, warp)
        {
            if (warp == nil || !warp)
                MapChatPane.Chat.deactivate(context);

            sActivatedMenuForRealEvent = false;

            foreach (var sip in [
                MapPane::ScalarInterpolator,
                MapChatPane::ScalarInterpolator,
                Parette::ScalarInterpolator,
                CarPane::ScalarInterpolator
            ])
            {
                sip.reverse = true;

                if (warp != nil && warp)
                    sip.warp();
                else
                    sip.start();
            }

            for (var i = 0; i < RacerPane.fixed_items.size; ++i)
                RacerPane.fixed_items[i].can_focus = false;

            RacerPane.Head.UserID.can_focus = false;
            RacerPane.Head.Car.can_focus = false;

            if (ORG.is_camera_subjective && gSequenceCondition.is_buffer_replay_mode)
                ORG.disp_meter = true;

            OnboardMeterRoot.visible = true;
        }

        method notifyMessageAdded()
        {
            View::MapChatPane.notifyAdded();
        }

        module CarPane
        {
            method initialize(context)
            {
                menu::LiveTimingUtil::RefreshCarPane(self, ORG);
            }

            method finalize(context)
            {

            }
        }

        module MapPane
        {
            method initialize(context)
            {
                MapClip.scale = [1, 1];

                MapClip::CourseMapFace.begin(ORG, MapClip, MapClip::ComCar, MapMode, MapScaleTable[MapScaleIndex], 0);

                MapController::HeadUp.active  = (MapMode == 1);
                MapController::NorthUp.active = (MapMode == 2);
                MapController::Fit.active     = (MapMode == 3);
            }

            method finalize(context)
            {
                MapClip::CourseMapFace.end();
            }

            module MapController
            {
                module ZoomUp
                {
                    method onFocusEnter(context)
                    {
                        RaceRoot.BalloonTip.visible = true;
                        RaceRoot.BalloonTip.set_value(context, self, 
                        context.translate(RaceRoot, "BALLOONTIP_MAP_ZOOMUP"), 0);

                        return EVENTRESULT_FILTER;
                    }

                    method onFocusLeave(context)
                    {
                        RaceRoot.BalloonTip.visible = false;
                        RaceRoot.BalloonTip.reset_value(context);
                        return EVENTRESULT_FILTER;
                    }

                    method onActivate(context)
                    {
                        if (MapScaleIndex > 0)
                        {
                            main::sound.play("cursor");
                            --MapScaleIndex;

                            MapClip::CourseMapFace.mapscale = MapScaleTable[MapScaleIndex];
                        }

                        return EVENTRESULT_FILTER;
                    }    
                }

                module ZoomDown
                {
                    method onFocusEnter(context)
                    {
                        RaceRoot.BalloonTip.visible = true;
                        RaceRoot.BalloonTip.set_value(context, self, 
                        context.translate(RaceRoot, "BALLOONTIP_MAP_ZOOMDOWN"), 0);

                        return EVENTRESULT_FILTER;
                    }

                    method onFocusLeave(context)
                    {
                        RaceRoot.BalloonTip.visible = false;
                        RaceRoot.BalloonTip.reset_value(context);
                        return EVENTRESULT_FILTER;
                    }

                    method onActivate(context)
                    {
                        if (MapScaleIndex < MapScaleTable.size - 1)
                        {
                            main::sound.play("cursor");
                            ++MapScaleIndex;

                            MapClip::CourseMapFace.mapscale = MapScaleTable[MapScaleIndex];
                        }

                        return EVENTRESULT_FILTER;
                    }    
                }

                module HeadUp
                {
                    method onFocusEnter(context)
                    {
                        RaceRoot.BalloonTip.visible = true;
                        RaceRoot.BalloonTip.set_value(context, self, 
                        context.translate(RaceRoot, "BALLOONTIP_MAP_HEADUP"), 0);

                        return EVENTRESULT_FILTER;
                    }

                    method onFocusLeave(context)
                    {
                        RaceRoot.BalloonTip.visible = false;
                        RaceRoot.BalloonTip.reset_value(context);
                        return EVENTRESULT_FILTER;
                    }

                    method onActivate(context)
                    {
                        if (!self.active)
                        {
                            main::sound.play("cursor");
                            MapMode = 1;

                            MapClip::CourseMapFace.mapmode = MapMode;

                            HeadUp.active = MapMode == 1;
                            NorthUp.active = MapMode == 2;
                            Fit.active = MapMode == 3;
                        }

                        return EVENTRESULT_FILTER;
                    }
                }

                module NorthUp
                {
                    method onFocusEnter(context)
                    {
                        RaceRoot.BalloonTip.visible = true;
                        RaceRoot.BalloonTip.set_value(context, self, 
                        context.translate(RaceRoot, "BALLOONTIP_MAP_NORTHUP"), 0);

                        return EVENTRESULT_FILTER;
                    }

                    method onFocusLeave(context)
                    {
                        RaceRoot.BalloonTip.visible = false;
                        RaceRoot.BalloonTip.reset_value(context);
                        return EVENTRESULT_FILTER;
                    }

                    method onActivate(context)
                    {
                        if (!self.active)
                        {
                            main::sound.play("cursor");
                            MapMode = 2;

                            MapClip::CourseMapFace.mapmode = MapMode;

                            HeadUp.active = MapMode == 1;
                            NorthUp.active = MapMode == 2;
                            Fit.active = MapMode == 3;
                        }

                        return EVENTRESULT_FILTER;
                    }
                }

                module Fit
                {
                    method onFocusEnter(context)
                    {
                        RaceRoot.BalloonTip.visible = true;
                        RaceRoot.BalloonTip.set_value(context, self, 
                        context.translate(RaceRoot, "BALLOONTIP_MAP_FIT"), 0);

                        return EVENTRESULT_FILTER;
                    }

                    method onFocusLeave(context)
                    {
                        RaceRoot.BalloonTip.visible = false;
                        RaceRoot.BalloonTip.reset_value(context);
                        return EVENTRESULT_FILTER;
                    }

                    method onActivate(context)
                    {
                        if (!self.active)
                        {
                            main::sound.play("cursor");
                            MapMode = 3;

                            MapClip::CourseMapFace.mapmode = MapMode;

                            HeadUp.active = MapMode == 1;
                            NorthUp.active = MapMode == 2;
                            Fit.active = MapMode == 3;
                        }

                        return EVENTRESULT_FILTER;
                    }
                }
            }
        }

        module MapChatPane
        {
            method set_visible()
            {
                Tab.active = MapChatTabChat;
                Map.visible = !Tab.active;
                Chat.visible = Tab.active;
            }

            method initialize(context)
            {
                if (GAME_STATUS.user_profile.option.lounge_demo)
                {
                    MapMode = 3;
                    MapChatTabChat = false;
                }

                Map.initialize(context);
                Chat.initialize(context, false);
                set_visible();
                Tab::Notice::ScalarInterpolator.warp();
            }

            method finalize(context)
            {
                Map.finalize(context);
                Chat.finalize(context);
            }

            method notifyAdded()
            {
                if (!Tab.active)
                    Tab::Notice::ScalarInterpolator.restart();
            }

            module Map
            {
                method initialize(context)
                {
                    MapClip.scale = [1, 1];

                    MapClip::CourseMapFace.begin(ORG, MapClip, MapClip::ComCar, MapMode, 
                    MapScaleTable[MapScaleIndex], 0);

                    MapController::HeadUp.active = (MapMode == 1);
                    MapController::NorthUp.active = (MapMode == 2);
                    MapController::Fit.active = (MapMode == 3);
                }

                method finalize(context)
                {
                    MapClip::CourseMapFace.end();
                }

