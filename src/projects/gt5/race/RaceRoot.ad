        if (PluginModule.defined("onExit"))
            PluginModule::onExit(context);
        else
        {
            main::sound.play("ok");
            OnboardMeterRoot::RaceDisplayFace.toStop();
            RaceMenuUtil::closeAction(context);
            ROOT.quit(context);
