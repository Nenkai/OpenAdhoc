    method onTimeLimit(context, limit_frame, elapsed_frame)
    {
        if (!gSequenceCondition.disable_replay_menu)
        {
            Info::TimeUp::ScalarInterpolator.restart();
            Info::TimeUp::ScalarInterpolator.pause = false;
            context.wait(1.0);
        }

        if (gSequenceCondition.repeat_replay)
        {
            ORG.endSession();
            context.wait(1.0);

            if (gSequenceCondition.disable_replay_menu)
                var start_session_camera_type = gtengine::StartSessionCameraType::SPECTATOR;
            
            else            
                var start_session_camera_type = gtengine::StartSessionCameraType::DISABLE_INPUT_WITHOUT_ZOOM;
            
            while (ORG.inSession())
                context.sync();

            ORG.startSession(nil, true, start_session_camera_type, false);
            context.pageInRootTransition();
            
            if (gSequenceCondition.is_logger_mode)
            {
                while (!ORG.inSession())
                    pdistd::DelayThread(0x3E8 * 0x64);

                while (!ORG.isFinishedFirstLoad())
                    pdistd::DelayThread(0x3E8 * 0x64);
                    
                while (!ORG.isRenderReady())
                    pdistd::DelayThread(0x3E8 * 0x64);
                    
                ORG.disableSoundingRace();
                ORG.getRaceSound().start = false;
                ORG.pauseAvailable = true;
                
                ROOT.replayStartByPauseState(context);
                RaceTimeAttackProject::DataLoggerRoot.resettingMonitor();
                RaceTimeAttackProject::DataLoggerRoot.setMonitorFadeIn(context);
            }

            ORG.setCamera(gtengine::CameraType::SPECTATOR);
            
        }

        else
        {
            quit(context);
        }
    }

    method onStartRaceRequest(context, starttime)
    {
        if (PluginModule.defined("onStartRaceRequest"))
            PluginModule::onStartRaceRequest(context, starttime);

        var is_demo = gSequenceCondition.isDemo();
        
        if (self.sBGMPlayFlags & 2)
        {
            SoundUtil::BGMPlayGroup(
            (is_demo ? ((gSequenceCondition.is_with_na) ? SoundUtil::SCENE_REPLAY_WITH_NA : SoundUtil::SCENE_REPLAY) 
            : SoundUtil::SCENE_RACE), "racing", nil, 0.0, 3.0);
        }

        else if (self.sBGMPlayFlags & 1)
        {
            var group = (gSequenceCondition.game_mode == main::gtengine::GameMode::LICENSE) ? "license_start" : "start";
            SoundUtil::RaceBGMPlayGroup(group, is_demo, SoundUtil::REPEAT_OFF);
        }
    }

    method onCountDown(context, count)
    {
        if (gSequenceCondition.isDemo())
            return;

        if (PluginModule.defined("onCountDown"))
            PluginModule::onCountDown(context, count);
            
        else
            onCountDownDefault(context, count, true);    
    }

    method onCountDownDefault(context, count, play_sound)
    {
        if (count <= 3)
        {
            if (play_sound)
                main::sound.play("count_d");

            var CD = Info::CountDown;
            
            CD.CD_1.visible = (count == 1) ? true : false;
            CD.CD_2.visible = (count == 2) ? true : false;
            CD.CD_3.visible = (count == 3) ? true : false;

            Info::CountDown::ScalarInterpolator.restart();
            Info::CountDown.visible = true;
        }
    }

    method onStartVehicleDefault(context, slot_id, disp_start, start_sound, target)
    {
        if (slot_id == target)
        {
            var is_demo = gSequenceCondition.isDemo();

            if (!is_demo)
            {
                if (disp_start && gSequenceCondition.isASpecPlaying())
                    Go_Message(true);

                if (start_sound)
                    main::sound.play("count_s");    
            }

            if (self.sBGMPlayFlags & 4)
            {
                SoundUtil::BGMPlayGroup(
                (is_demo ? ((gSequenceCondition.is_with_na) ? SoundUtil::SCENE_REPLAY_WITH_NA : SoundUtil::SCENE_REPLAY) 
                : SoundUtil::SCENE_RACE), "racing", nil, 0.0, 3.0);
            }
        }
    }

    method onStartVehicle(context, slot_id, disp_start, start_sound)
    {
        Info::CountDown.visible = false;

        if (gSequenceCondition.game_mode == main::gtengine::GameMode::ONLINE_ROOM)
            var target = RaceOperator.getAccountSlotID(0);

        else
            var target = RaceOperator.representative_slot_id;
            
        if (PluginModule.defined("onStartVehicle"))
            PluginModule::onStartVehicle(context, slot_id, disp_start, start_sound, target);
                
        else
            onStartVehicleDefault(context, slot_id, disp_start, start_sound, target);     
    }

