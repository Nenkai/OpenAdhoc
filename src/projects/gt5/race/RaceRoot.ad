    }

    function CheckUnlockTrophyHondaAtHondaSingle(tuner, slot)
    {
        if (tuner == nil)
            return false;

        if (slot == nil)
            return false;
            
        var minX = -589.65;
        var maxX = -458.7;
        var minZ = 438.9;
        var maxZ = 473.1;
        
        if (tuner != "tuner_honda" && tuner != "tuner_acura")
            return false;

        var hondaPos = ORG.getVehiclePosition(slot);
        if ((hondaPos[0] >= minX && hondaPos[0] <= maxX) && (hondaPos[2] >= minZ && hondaPos[2] <= maxZ))
        {
            var size = ORG.getCarLODSize([slot]);
            if (size >= 1080.0 / 10.0)
                return true;
        }

        return false;
    }

    function CheckUnlockTrophyHondaAtHonda(carTunerList, slotList)
    {
        if (carTunerList == nil)
            return false;

        if (slotList == nil)
            return false;
            
        var num = slotList.size;
        for (var i = 0; i < num; ++i)
        {
            if (CheckUnlockTrophyHondaAtHondaSingle(carTunerList[i], slotList[i]))
                return true;
        }

        return false;
    }

    module Foot
    {
        method initialize(context)
        {
            if (gSequenceCondition.isASpecPlaying() || gSequenceCondition.disable_replay_menu)
            {
                Head.visible = false;
                Foot.visible = false;
                ROOT.sEnablePhoto = false;
            }
            else
            {
                PhotoButton::HBox::Photo.visible = false;
                PhotoButton::HBox::EasyPhoto.visible = false;
                PauseAndPhoto.visible = false;
                LoggerStartReplay.visible = false;
                LoggerStopReplay.visible = false;

                LoggerGotoHead.visible = false;
                LoggerHelp.visible = false;
                LoadReference.visible = false;
                Button::ViewChangeLogger.visible = false;

                Button::ViewDispOff.visible = false;
                ButtonChat.visible = false;
                Foot::GotoHead.visible = false;
                Foot::GotoBack.visible = false;
                Foot::GotoNext.visible = false;
                changeChapterState(context);

                Head.visible = true;
                Foot.visible = true;
                activateFoot(context);

                if (gSequenceCondition.enable_director_command && !gSequenceCondition.is_buffer_replay_mode)
                {
                    ORG.noDispBackMirror(true);
                    BSpec.initialize(context);
                    Button::ScalarInterpolator.reverse = true;
                    Button::ScalarInterpolator.warp();

                    ROOT.sEnablePhoto = false;

                    var ps = ORG.getCurrentPitStrategy(getPlayerSlot(0), true);
                    ps.amount_of_petrol = ps.fuel_tank_size;
                    ORG.startVehiclePitWork(getPlayerSlot(0), ps);
                    BSpec::PitStrategyButton.visible = RaceOperator.race_parameter.enable_pit;
                    setFullView(context);
                }
                else if (gSequenceCondition.is_logger_mode)
                {
                    Head.visible = false;
                    BSpec.visible = false;
                    Button::ScalarInterpolator.reverse = false;
                    Button::ScalarInterpolator.warp();

                    ROOT.sEnablePhoto = false;
                    LoggerStartReplay.visible = true;
                    LoggerStopReplay.visible = true;
                    LoggerGotoHead.visible = true;
                    LoggerHelp.visible = true;
                    LoadReference.visible = true;

                    Button::ViewFull.visible = false;
                    Button::ViewLT.visible = false;
                    Button::ViewChange.visible = false;
                    Button::ViewChangeLogger.visible = true;
                    setDataLoggerView(context);
                }
                else if (gSequenceCondition.is_online && !gSequenceCondition.is_buffer_replay_mode)
                {
                    ButtonChat.visible = true;
                    ORG.noDispBackMirror(true);
                    BSpec.visible = false;

                    Button::ScalarInterpolator.reverse = true;
                    Button::ScalarInterpolator.warp();

                    ROOT.sEnablePhoto = false;
                    PauseAndPhoto.visible = ROOT.sEnablePhoto;
                    Button::ViewChange.visible = false;
                    BSpec::PitStrategyButton.visible = false;

                    if (GAME_STATUS.user_profile.option.lounge_demo)
                    {
                        var button_start = Lobby.isRoomOwner() && ORG.racers_num > 0;
                        ButtonStart.active = button_start;
                        ButtonStart.visible = Lobby.isRoomOwner() && ORG.racers_num > 0;
                    }

                    setFullView(context);
                }
                else
                {
                    BSpec.visible = false;
                    ROOT.sEnablePhoto = __projects__.defined("PhotoProject");
                    PauseAndPhoto.visible = ROOT.sEnablePhoto;

                    Foot::PauseAndPhoto::label_only_pause.visible = false;
                    Button::ViewFull.visible = true;
                    Button::ViewLT.visible = true;
                    Button::ViewChange.visible = true;

                    OnboardMeterRoot.appearPanel();
                    ROOT.deactivateFoot(context, true);
                    setFullView(context, true);

                    Foot::PhotoButton::HBox::Photo.visible = false;
                    Foot::PhotoButton::HBox::EasyPhoto.visible = false;
                    Foot::GotoHead.visible = gSequenceCondition.repeat_replay;

                    if (ORG.canSkipChapter() && ORG.isLicenseCameraTable() == false && !gSequenceCondition.is_arena)
                    {
                        Foot::GotoBack.visible = true;
                        Foot::GotoNext.visible = true;
                    }
                }
            }
        }

        method finalize(context)
        {
            if (gSequenceCondition.enable_director_command)
                BSpec.finalize(context);

            if (self.current_view != nil)
                self.current_view.finalize(context);

            self.endLeaveDetect(context);
            Foot.visible = false;
            context.cursor_visible = false;
        }

        method refresh(context)
        {
            if (self.current_view != nil)
                self.current_view.refresh(context);

            if (BSpec.visible)
                BSpec.refresh(context);

            if (GAME_STATUS.user_profile.option.lounge_demo)
            {
                var button_start = Lobby.isRoomOwner() && ORG.racers_num > 0;
                ButtonStart.active = button_start;
                ButtonStart.visible = Lobby.isRoomOwner() && ORG.racers_num > 0;
            }
        }

        method setFullView(context, initial_out)
        {
            if (Button::ViewFull.active && Foot.current_view == FullViewRoot)
                return;

            Button::ViewFull.active = true;
            Button::ViewLT.active = false;
            Head::Current.translate_x = 0.1;
            changePauseState(context);
            ORG.disableRenderingRace();

            if (Foot.current_view != nil)
                Foot.current_view.finalize(context);

            FullViewRoot.initialize(context, ROOT::LTBase, initial_out);
            Foot.current_view = FullViewRoot;
            ORG.enableRenderingRace();
        }

        method setDataLoggerView(context)
        {
            if (Foot.current_view == RaceTimeAttackProject::DataLoggerRoot)
                return;

            Button::ViewFull.active = false;
            Button::ViewLT.active = false;
            Head::Current.translate_x = 0;
            changePauseState(context, false);
            ORG.disableRenderingRace();

            if (Foot.current_view != nil)
                Foot.current_view.finalize(context);

            RaceTimeAttackProject::DataLoggerRoot.initialize(context, ROOT::LTBase);
            sLoggerGotoHeadProcess = 1;
            Foot.current_view = RaceTimeAttackProject::DataLoggerRoot;
            ORG.enableRenderingRace();
        }

        method setLiveTimingView(context)
        {
            if (Button::ViewLT.active && Foot.current_view == LiveTimingRoot)
                return;

            Button::ViewFull.active = false;
            Button::ViewLT.active = true;
            Head::Current.translate_x = 0;
            changePauseState(context);
            ORG.disableRenderingRace();

            if (Foot.current_view != nil)
                Foot.current_view.finalize(context);

            LiveTimingRoot.initialize(context, ROOT::LTBase);
            Foot.current_view = LiveTimingRoot;
            ORG.enableRenderingRace();
        }

        method directorCommandActive(context)
        {
            BSpec::Director.active = true;

            var color = main::menu::MColorObject(255, 255, 255, 255);
            BSpec::Director::Cur.face_color = color;
            BSpec::Director::CurWait.face_color = color;
        }

        method directorCommandDeActive(context, is_no_change_focus)
        {
            BSpec::Director.active = false;
            BSpec::Director::Cur.image_path = "image/gt5/race_view/b_command_blank.dds";
            BSpec::Director::CurWait.image_path = "image/gt5/race_view/b_command_blank.dds";

            var color = main::menu::MColorObject(10, 10, 10, 150);
            BSpec::Director::Cur.face_color = color;
            BSpec::Director::CurWait.face_color = color;

            if (is_no_change_focus != nil && is_no_change_focus)
                BSpec::Command.close(context, -2);
            else
                BSpec::Command.close(context, -1);
        }

        module ButtonStart
        {
            method onFocusEnter(context)
            {
                ROOT.BalloonTip.visible = true;
                ROOT.BalloonTip.set_value(context, self, 
                context.translate(ROOT, "BALLOONTIP_START"), 0);

                return EVENTRESULT_FILTER;
            }

            method onFocusLeave(context)
            {
                ROOT.BalloonTip.visible = false;
                ROOT.BalloonTip.reset_value(context);
                return EVENTRESULT_FILTER;
            }

            method onActivate(context)
            {
                if (!self.active)
                    main::sound.play("disable");
                    return EVENTRESULT_FILTER;

                OnlineSession.prepareNetworkRace(10 * 1000);
                return EVENTRESULT_FILTER;
            }
        }

        module BSpec
        {
            static sSoundEffectHolder = nil;

            method initialize(context)
            {
                Director.initialize(context);
                DriverMonitor.initialize(context);
                DriverList.initialize(context);
                Command.initialize(context);
                Command.hide(context);

                BSpecMeterFace.begin(main::ORG, Foot::BSpec);
                Head.visible = true;
                sSoundEffectHolder = [main::pdiext::MSoundEffect("sound_gt/se/gt5bspec.sgd")];
                self.visible = true;
                BSpecMeterFace.BSpecDevelopGaugeDisp(true);
            }

            method refresh(context)
            {
                DriverMonitor.refresh(context);
                DriverList.refresh(context);
            }

            method finalize(context)
            {
                BSpecMeterFace.BSpecDevelopGaugeDisp(false);
                self.visible = false;
                BSpecMeterFace.end();
                sSoundEffectHolder = nil;
                Head.visible = false;
            }

            module Director
            {
                method initialize(context)
                {
                    self.active = true;
                    Gauge::ScalarInterpolator.reset();
                    Cur.image_path = "image/gt5/race_view/b_command_blank.dds";
                    CurWait.image_path = "image/gt5/race_view/b_command_blank.dds";

                    var color = main::menu::MColorObject(255, 255, 255, 255);
                    BSpec::Director::Cur.face_color = color;
                    BSpec::Director::CurWait.face_color = color;
                }

                method onActivate(context)
                {
                    if (Gauge.opacity > 0.5 || !self.active)
                    {
                        main::sound.play("disable");
                        return EVENTRESULT_FILTER;
                    }

                    main::sound.play("ok");
                    ROOT::Foot::BSpec::DriverList.visible = false;
                    self.active = false;
                    LeaveDetectUtil::suspend(context);

                    var idx = Command.open(context);
                    LeaveDetectUtil::resume(context);

                    if (idx != nil && idx >= 0)
                    {
                        var cname = Command::commands[idx][0];
                        Cur.image_path = "image/gt5/race_view/b_command_%{cname}.dds";
                        ORG.issuePitMessage(Command::commands[idx][1], RaceOperator.representative_slot_id);

                        Cur.ScalarInterpolator.restart();
                        CurWait.ScalarInterpolator.restart();
                        Gauge::ScalarInterpolator.restart();
                        Gauge::gauge::ScalarInterpolator.restart();
                        DriverMonitor::Response.sayOK(context);
                    }

                    context.sync(0.1);
                    self.active = true;
                    return EVENTRESULT_FILTER;
                }
            }

            module PitStrategyButton
            {
                method onActivate(context)
                {
                    var slot_id = getPlayerSlot(0);

                    if (ORG.checkSlotPitInStatus(slot_id) > 0)
                    {
                        main::sound.play("disable");
                        return EVENTRESULT_FILTER;
                    }

                    main::sound.play("ok");
                    var event = gSequenceCondition.gp.event;
                    var constraint = event.constraint;
                    var regulation = event.regulation;
                    var invalid = gtengine::MGameParameter::INVALID_VALUE_INT;
                    var data = PitStrategy::Data();
                    data.slot_id = slot_id;

                    data.limit_tire_f = System::Math::min((constraint.limit_tire_f != invalid) ? constraint.limit_tire_f : 0x7FFFFFFF, 
                        (regulation.limit_tire_f != invalid) ? regulation.limit_tire_f : 0x7FFFFFFF);

                    if (data.limit_tire_f == 2147483647)
                        data.limit_tire_f = invalid;

                    data.need_tire_f = System::Math::max(constraint.need_tire_f, regulation.need_tire_f);

                    data.limit_tire_r = System::Math::min((constraint.limit_tire_r != invalid) ? constraint.limit_tire_r : 0x7FFFFFFF, 
                        (regulation.limit_tire_r != invalid) ? regulation.limit_tire_r : 0x7FFFFFFF);

                    if (data.limit_tire_r == 0x7FFFFFFF)
                        data.limit_tire_r = invalid;

                    data.need_tire_r = System::Math::max(constraint.need_tire_r, regulation.need_tire_r);

                    var pit_strategy = ORG.getCurrentPitStrategy(getPlayerSlot(0));
                    LeaveDetectUtil::suspend(context);
                    PitStrategy.open(context, data, pit_strategy, true);
                    LeaveDetectUtil::resume(context);

                    return EVENTRESULT_FILTER;
                }
            }

            module DriverList
            {
                static useDriverList = false;

                method initialize(context)
                {
                    self.visible = false;
                    useDriverList = true;

                    var widget_list = [];
                    widget_list.push(DriverList::Vbox::List.Driver1);
                    widget_list.push(DriverList::Vbox::List.Driver2);
                    widget_list.push(DriverList::Vbox::List.Driver3);

                    foreach (var driver in widget_list)
                    {
                        driver.visible = false;
                        var progress = pdistd::MProgress();
                        driver.Physical::ProgressFace.progress = progress;
                        driver.Physical::ProgressFace.linear_mode = true;
                        driver.Physical::ProgressFace.decreasable = true;
                    }

                    var list = GAME_STATUS.user_profile.residence.getEntryDriverList();
                    var size = list.size - 1;
                    for (var i = 0; i < size; ++i)
                        widget_list[i].visible = true;

                    refresh(context);
                }

                method refresh(context)
                {
                    if (!useDriverList)
                        return EVENTRESULT_FILTER;

                    var list = GAME_STATUS.user_profile.residence.getEntryDriverList();
                    var size = list.size - 1;

                    if (size < 1)
                        return EVENTRESULT_FILTER;

                    var widget_list = [];
                    widget_list.push(DriverList::Vbox::List.Driver1);
                    widget_list.push(DriverList::Vbox::List.Driver2);
                    widget_list.push(DriverList::Vbox::List.Driver3);

                    var camera_target = ORG.getCameraTarget(0);
                    var entried_dp = ORG.getEntriedDriverParameter(camera_target);

                    if (entried_dp == nil)
                        return EVENTRESULT_FILTER;

                    var driver_id = 0;
                    var player_slot = RaceOperator.getPlayerSlot(0);
                    var ridding_id = ORG.getRidingDriverIndex(player_slot);

                    if (camera_target != player_slot)
                    {
                        ROOT::Foot::BSpec::DriverList.visible = false;
                        return EVENTRESULT_FILTER;
                    }

                    foreach (var widget in widget_list)
                    {
                        if (widget.visible)
                        {
                            var dp = list[driver_id][1];
                            if (driver_id == ridding_id)
                            {
                                driver_id++;
                                dp = list[driver_id][1];
                            }

                            widget.Name.text = dp.display_name;
                            var avatar_helmet_id = dp.head_color_code;
                            widget.met.image_path = "piece/avatar_helmet/%{avatar_helmet_id}.img";

                            widget.met.image_path = ThumbnailUtil::Avatar::getImagePath(
                                ThumbnailUtil::Avatar::Genre::SIMPLE,
                                ThumbnailUtil::Avatar::Type::MET,
                                "M", 
                                dp.head_code, dp.head_color_code,
                                dp.body_code, dp.body_color_code
                            );

                            widget.met.visible = true;
                            driver_id++;
                        }
                    }
                }
            }

            module DriverMonitor
            {
                method initialize(context)
                {
                    var camera_target = ORG.getCameraTarget(0);
                    var entried_dp = ORG.getEntriedDriverParameter(camera_target);

                    if (entried_dp != nil)
                    {
                        var driver = GAME_STATUS.user_profile.residence.getContractDriver(entried_dp.residence_id);
                        var dp;

                        if (driver == nil)
                            dp = entried_dp;
                        else
                            dp = driver[1];

                        label.text = dp.display_name;
                        labela.text = dp.display_name;
                    }
                    else
                    {
                        label.text = "";
                        labela.text = "";
                    }

                    if (camera_target == RaceOperator.getPlayerSlot())
                        self.active = true;
                    else
                        self.active = false;

                    Response.initialize(context);
                    var progress = pdistd::MProgress();
                    Physical::ProgressFace.progress = progress;
                    Physical::ProgressFace.linear_mode = true;
                    Physical::ProgressFace.decreasable = true;

                    var progress = pdistd::MProgress();
                    Mental::ProgressFace.progress = progress;
                    Mental::ProgressFace.linear_mode = true;
                    Mental::ProgressFace.decreasable = true;
                }

                method refresh(context)
                {
                    var camera_target = ORG.getCameraTarget(0);
                    var entried_dp = ORG.getEntriedDriverParameter(camera_target);
                    var dp;

                    if (entried_dp == nil)
                        return;

                    if (camera_target == RaceOperator.getPlayerSlot())
                    {
                        self.active = true;
                        ROOT::Foot::directorCommandActive(context);
                        var driver = GAME_STATUS.user_profile.residence.getContractDriver(entried_dp.residence_id);

                        if (driver == nil)
                            dp = entried_dp;
                        else
                            dp = driver[1];
                    }
                    else
                    {
                        self.active = false;
                        ROOT::Foot::directorCommandDeActive(context, true);
                        dp = entried_dp;
                    }

                    label.text = dp.display_name;
                    labela.text = dp.display_name;
                    var avatar_helmet_id = dp.head_color_code;

                    if (avatar_helmet_id >= 0 && self.active)
                    {
                        met.image_path = ThumbnailUtil::Avatar::getImagePath(
                            ThumbnailUtil::Avatar::Genre::SIMPLE,
                            ThumbnailUtil::Avatar::Type::MET,
                            "M", 
                            dp.head_code, dp.head_color_code,
                            dp.body_code, dp.body_color_code
                        );

                        met.visible = true;
                        met_rival.visible = false;
                    }
                    else
                    {
                        met.visible = false;
                        met_rival.visible = true;
                    }
                }

                method onActivate(context)
                {
                    var list = GAME_STATUS.user_profile.residence.getEntryDriverList();
                    var size = list.size - 1;

                    if (size < 1)
                    {
                        main::sound.play("cancel");
                        return EVENTRESULT_FILTER;
                    }

                    var camera_target = ORG.getCameraTarget(0);
                    var player_slot = RaceOperator.getPlayerSlot(0);

                    if (camera_target != player_slot)
                    {
                        main::sound.play("cancel");
                        ROOT::Foot::BSpec::DriverList.visible = false;
                        return EVENTRESULT_FILTER;
                    }

                    if (ROOT::Foot::BSpec::DriverList.visible)
                    {
                        main::sound.play("cancel");
                        ROOT::Foot::BSpec::DriverList.visible = false;
                    }
                    else
                    {
                        main::sound.play("ok");
                        ROOT::Foot::BSpec::DriverList.visible = true;
                    }

                    return EVENTRESULT_FILTER;
                }

                module Response
                {
                    method initialize(context)
                    {
                        label.text = "";
                        ScalarInterpolator.reset();
                    }

                    method sayOK(context)
                    {
                        label.text = context.translate(ROOT, "OK");
                        ScalarInterpolator.restart();
                        main::sound.play("response_normal");
                    }
                }
            }

            module Command
            {
                static commands = [
                    ["pacedown", gtengine::PitMessageType::PACE_DOWN],
                    ["pacekeep", gtengine::PitMessageType::PACE_KEEP],
                    ["paceup", gtengine::PitMessageType::PACE_UP],
                    ["overtake", gtengine::PitMessageType::OVERTAKE],
                    ["pitin", gtengine::PitMessageType::PITIN],
                    ["pitcancel", gtengine::PitMessageType::PITIN_CANCEL]
                ];

                attribute result;
                attribute level;

                method initialize(context)
                {
                    var listbox = ListBox;
                    self.level = nil;
                    listbox.stop_key_event = true;

                    listbox.setItemTemplate(context, hidden::CommandItem);
                    var size = commands.size;

                    if (!RaceOperator.race_parameter.enable_pit)
                        size = commands.size - 2;

                    listbox.setItemCount(size);

                    for (var i = 0; i < size; ++i)
                    {
                        var cname = commands[i][0];
                        var w = listbox.getItemWidget(i, context);
                        w.bg.image_path = "image/gt5/race_view/b_command_%{cname}.dds";
                    }

                    ListBox::ScalarInterpolator.setEndValue(0, 160 * size);
                }

                method open(context)
                {
                    self.result = -1;
                    self.appear(context);
                    context.enterEventLoop(&self.level);

                    return self.result;
                }

                method close(context, res)
                {
                    if (res >= 0)
                        self.disappear(context);
                    else if (res == -2)
                        self.hide(context);
                    else
                    {
                        self.hide(context);
                        ROOT.setFocus(Director);
                    }

                    self.result = res;

                    if (self.level != nil)
                        context.leaveEventLoop(self.level);

                    self.level = nil;
                }

                method hide(context)
                {
                    self.visible = false;
                    ListBox::ScalarInterpolator.reverse = true;
                    ListBox::ScalarInterpolator.reset();
                }

                method appear(context)
                {
                    self.visible = true;
                    ListBox::ScalarInterpolator.reverse = false;
                    ListBox::ScalarInterpolator.start();
                    ROOT.setFocus(ListBox);
                }

                method disappear(context)
                {
                    ListBox::ScalarInterpolator.reverse = true;
                    ListBox::ScalarInterpolator.start();
                    context.wait(0.5);

                    ROOT.setFocus(Director);
                    self.visible = false;
                }

                module ListBox
                {
                    method onActivate(context)
                    {
                        main::sound.play("instruction");
                        Command.close(context, self.focus_index);
                        return EVENTRESULT_FILTER;
                    }

                    method onCancel(context)
                    {
                        main::sound.play("cancel");
                        Command.close(context, -1);
                        return EVENTRESULT_FILTER;
                    }

                    method onFocusChanged(context, new_index)
                    {
                        if (new_index < 0)
                            return EVENTRESULT_FILTER;

                        ROOT.BalloonTip.visible = true;
                        var cname = Command::commands[new_index][0].upcase();
                        var w = self.getItemWidget(new_index);

                        ROOT.BalloonTip.set_value(context, w, 
                        context.translate(ROOT, "BALLOONTIP_COMMAND_%{cname}"), 0);

                        return EVENTRESULT_FILTER;
                    }

                    method onFocusEnter(context)
                    {
                        return onFocusChanged(context, self.focus_index);
                    }

                    method onFocusLeave(context)
                    {
                        ROOT.BalloonTip.visible = false;
                        ROOT.BalloonTip.reset_value(context);
                        return EVENTRESULT_FILTER;
                    }
                }
            }
        }

