



module ROOT
{
    #include "KeyboardSwitcher.ad"

    hidden.visible = false;

    static sLoggerGotoHeadProcess = 1;
    static sWatcher;
    static sDemoCameraWatcher;
    static sDriftFirstFrame = false;

    static sDriftScale = 2.0;
    static sDriftOldScore = 0.0;
    static sDriftIntervalFrame = 0;
    static sDriftOldState = 0;
    static sDriftPrevNoteRate = 0;
    static sDriftBlinkNow = 0;
    static sDriftSoundEffectHolder = nil;
    static sViewChangeWatcher = nil;

    function view_change_tick(context)
    {
        ORG.callDriversViewChange();
    }

    method onUnload(context)
    {
        ORG.window_max = 1;
        ORG.race_display_window_num = 1;
    }

    static sAlreadyQuited = false;
    attribute sNormalFinish = false;
    attribute sLastConditionSatisfied = false;
    attribute sEnablePhoto = false;
    static isPhotoPreview = false;

    method setTarget(target, window_id)
    {
        if (window_id == nil)
            var window_id = 0;

        main::ORG.setCameraTarget(window_id, target);
        main::ORG.setRaceDisplayTarget(window_id, target);
    }

    method getTarget(window_id)
    {
        if (window_id == nil)
            var window_id = 0;

        return main::ORG.getCameraTarget(window_id);
    }

    method onLeaveDetectToQuit(context)
    {
        self.quit_and_goto_top(context);
    }

    function Go_Message(toinit)
    {
        var W = Info::Go;
        W.visible = false;
        Info.need_update = true;
        Info::Go.need_update = true;

        if (toinit == true)
        {
            W.ScalarInterpolator.restart();
            W.VectorInterpolator.restart();
            W.ImageFace0::ScalarInterpolator.restart();
            W.visible = true;
        }
    }

    function GoalMessage(finish, win, lose, succ, disq)
    {
        var W = Info::Goal;
        W.visible = false;

        if (finish || win || lose || succ || disq)
        {
            W.ScalarInterpolator.restart();
            W.VectorInterpolator.restart();

            W.Finish.visible = finish;
            W.FinishFlash.visible = finish;
            W.FinishFlash::ScalarInterpolator.restart();

            W.Win.visible = win;
            W.Lose.visible = lose;
            W.Success.visible = succ;
            W.Disqualify.visible = disq;

            W.visible = true;
        }
    }

    method resetDisplay(context)
    {
        ROOT.visible = true;
        Info::CountDown.visible = false;
        Info::Winner.visible = false;

        Info::Winner.x = pdiext::MSystemConfiguration::is4x3() ? 1564 - 240 : 1564;
        Info::RemainTime.visible = false;
        Info::RemainTime.x = pdiext::MSystemConfiguration::is4x3() ? 1584 - 240 : 1584;

        Go_Message(false);
        Info::TimeUp::ScalarInterpolator.reset();
        GoalMessage(false, false, false, false, false);
        Info::ReplayResult.visible = false;
        Info::ReplayResult::ScalarInterpolator.reset();

        Info::NextEnemy.visible = false;
        Info::OvertakeResult.visible = false;
        Info::CourseAnnounce.visible = false;
        Foot::MessageWindow.visible = false;
        Foot::GotoHead.visible = false;
        Foot::GotoBack.visible = false;
        Foot::GotoNext.visible = false;
        Foot::PhotoButton::HBox::Photo.visible = false;
        Foot::PhotoButton::HBox::EasyPhoto.visible = false;

        var assign = main::pdiext::MSystemConfiguration::GetEnterButtonAssign();
        var button_circle = true;

        if (assign != "circle")
            var button_circle = false;

        AfterShootingHelp.visible = false;
        AfterShootingHelp::Pane::Buttons::Save::Circle.visible = button_circle;
        AfterShootingHelp::Pane::Buttons::Save::Cross.visible = !button_circle;
        AfterShootingHelp::Pane::Buttons::Back::Circle.visible = !button_circle;
        AfterShootingHelp::Pane::Buttons::Back::Cross.visible = button_circle;

        OnboardMeterRoot.appearPanel();
        OnboardMeterRoot::RaceDisplayFace.setOnlineRecord(0);
        OnboardMeterRoot::RaceDisplayFace.setMyOnlineRecord(0);

        if (gSequenceCondition.is_buffer_replay_mode)
            OnboardMeterRoot::RaceDisplayFace.setRemainMaxTime(0);
        else
            OnboardMeterRoot::RaceDisplayFace.setRemainMaxTime(((1000 * 60) * 1000) - 1);

        Info::DriftScore.visible = false;
        Info::DriftScore.TextFace.text = context.translate(ROOT, "RaceProject::OnboardMeterRoot", "Drift_Point");

        sDriftOldScore = 0.0;
        sDriftScale = 5.0;
        sDriftIntervalFrame = 0;
        sDriftOldState = 0;
        sDriftPrevNoteRate = 0;
        sDriftBlinkNow = 0;

        switch (main::GAME_STATUS.config.drift_flag)
        {
            case 0:
                Info::DriftScore::Meter::add.visible = true;
                Info::DriftScore::Meter::add_real.visible = false;
                break;
                
            default:               
                Info::DriftScore::Meter::add.visible = false;
                Info::DriftScore::Meter::add_real.visible = true;
                break;              
        }
    }

    method onInitialize(context)
    {
        ORG.setEventCallback(context, ROOT);
        self.createPauseMenu(context);
        main::ORG.fetchRaceDisplay();
        var state = main::ORG.getRaceDisplayState(0);

        var is_da = RaceOperator.race_parameter.race_type == main::gtengine::GameMode::DRIFT_ATTACK;
        var is_st = RaceOperator.race_parameter.race_type == main::gtengine::GameMode::SPEED_TEST;

        if (sWatcher == nil)
            sWatcher = WatcherUtil::Create(context, onTick);

        if (main::GAME_STATUS.defined("branch") && main::GAME_STATUS.branch.defined("demo_camera_target_random") && main::GAME_STATUS.branch.demo_camera_target_random && sDemoCameraWatcher == nil)
        {
            main::ORG.setCamera(main::gtengine::CameraType::SPECTATOR);
            sDemoCameraWatcher = WatcherUtil::Create(context, onDemoCameraTick, 10 * 60);
        }

        if (is_da || is_st)
        {
            sDriftFirstFrame = true;
            sDriftSoundEffectHolder = [main::pdiext::MSoundEffect("sound_gt/se/gt5pdrift.sgd")];
        }

        ORG.pauseHandleAvailable = false;
        ORG.pauseAvailable = false;
        checkWetInfoVisibleCondition();
        main::ORG.window_max = main::RaceOperator.window_max;

        sAlreadyQuited = false;
        resetDisplay(context);
        gSequenceCondition.is_riding_car = true;
        var event = gSequenceCondition.gp.event;

        if (event.eval_condition.type == main::gtengine::EvalType::VS_GHOST)
        {
            Info::ReplayResult.visible = true;
            Info::ReplayResult::ScalarInterpolator.restart();
            Info::ReplayResult::Record::HBox::record.text = main::pdiext::GetRaceTimeString(event.eval_condition.gold);

            Info::ReplayResult::Record::HBox::unit.text = "";
            Info::ReplayResult::PlayerName.text = event.information.one_line_title.getText();
            Info::ReplayResult::PlayerName.visible = true;
        }

        Head::RaceHeadrFace.begin4headlap(main::ORG, Head);
        Head::Current.translate_x = 0;
        Info::WarningMessage.visible = false;
        Info::MaxSpeed.visible = false;

        if (gSequenceCondition.is_buffer_replay_mode)
            startMaxSpeedView(context);

        if (gSequenceCondition.is_arena)
            ORG.bspec_dev_skill_gauge = true;

        if (PluginModule.defined("onBeforeSession"))
            PluginModule::onBeforeSession(context);

        if (!gSequenceCondition.disable_start_session)
        {
            var start_session_success = gSequenceCondition.startSessionForRace();
            if (!start_session_success)
            {
                context.pushEvent(main::menu::MScriptEvent(context, self, "on_failed_to_start_session"));
                return;
            }
        }

        if (gSequenceCondition.isASpecPlaying() && GAME_STATUS.user_profile.option.timeout_count_to_topmenu > 0 && !gSequenceCondition.is_online)
        {
            LeaveDetectUtil::begin(context, main::GAME_STATUS.user_profile.option.timeout_count_to_topmenu, self, self.onLeaveDetectToQuit, nil);
        }

        var is_ta = RaceOperator.race_parameter.race_type == main::gtengine::GameMode::TIME_ATTACK;
        if (is_ta && gSequenceCondition.is_buffer_replay_mode && gSequenceCondition.is_logger_mode)
        {
            var head_buf = ORG.getReplayHeaderFromPath(ORG.replay_work_path);
            var info = gtengine::MReplayInfo();
            var success = info.initialize(head_buf);
            var stream_file = pdistd::GetFileStatus(ORG.replay_work_path);
            var total_size = stream_file["size"];

            var datalogger = gtengine::MDataLogger();
            datalogger.setRaceControl(ORG);

            var result = datalogger.beginLoggerData(ORG.replay_work_path, head_buf, total_size, 0, false);
            set_dt(0.0);
        }

        if (!gSequenceCondition.isDemo())
        {
            for (var i = 0; i < main::RaceOperator.window_max; i++)
            {
                var slot_id = RaceOperator.getPlayerSlot(i);
                setTarget(slot_id, i);
            }
        }

        Foot.initialize(context);
        var chat_input_list = [PROJECT::ROOT::ChatInput, Foot::ChatInput];

        if (UIKitProject::MessengerRoot.defined('ChatInput'))
            chat_input_list.push(UIKitProject::MessengerRoot::ChatInput);

        foreach (var chat_input in chat_input_list)
        {
            chat_input.visible = false;

            if (chat_input.x < 160.0)
                chat_input.x = 160.0;

            if (context.class_id.defined('osk_screen_height'))
            {
                var h = 56.0;
                if (context.osk_display_height < 720)
                    h = 33.0;
                else if (context.osk_display_height < 1080)
                    h = 45.0;

                var s = 1080.0 / context.osk_screen_height.toFloat();
                chat_input.h = h * s;
            }
        }

        self.BalloonTip.initialize(context);
        self.BalloonTip.visible = false;

        SoundUtil::SetupSound(
            gSequenceCondition.isDemo() ? 
                ((gSequenceCondition.is_with_na) ? SoundUtil::SCENE_REPLAY_WITH_NA : SoundUtil::SCENE_REPLAY) 
                : SoundUtil::SCENE_RACE
        );

        gRaceBGM.onRaceRootInitialize(gSequenceCondition.isDemo(), gSequenceCondition.is_online, 
        gSequenceCondition.is_buffer_replay_mode, gSequenceCondition.is_with_na);

        ROOT.visible = true;
        OnboardMeterRoot.visible = true;
        ORG.enableRenderingRace();

        if (is_ta && gSequenceCondition.is_buffer_replay_mode && gSequenceCondition.is_logger_mode)
        {
            ORG.disableSoundingRace();
            ORG.getRaceSound().start = false;
        }
        else
        {
            ORG.enableSoundingRace();
            ORG.getRaceSound().start = true;
        }

        if (PluginModule.defined("onRaceRootInitialize"))
            PluginModule::onRaceRootInitialize(context, ROOT);

        while (ORG.setEventSignalWait(false) == false)
            context.sync();

        resetFocus(ROOT);
        ROOT.sNormalFinish = false;
        ROOT.sLastConditionSatisfied = false;

        if (AppOpt.defined("autorun_viewchange"))
            sViewChangeWatcher = WatcherUtil::Create(context, view_change_tick, 60 * 5);

        if (RaceOperator.isTheater() || gSequenceCondition.is_logger_mode || gSequenceCondition.is_buffer_replay_mode)
        {
            if (gSequenceCondition.is_logger_mode)
            {
                ORG.pauseHandleAvailable = false;

                while (!ORG.isFinishedFirstLoad())
                    pdistd::DelayThread(1000 * 100);

                while (!ORG.isRenderReady())
                    pdistd::DelayThread(1000 * 100);

                ROOT.replayStartByPauseState(context);
                ORG.pauseRace = true;
            }
            else
                ORG.pauseRace = false;
        }
        else
        {
            if (gSequenceCondition.isASpecPlaying())
            {
                ORG.pauseHandleAvailable = true;

                if (gSequenceCondition.is_online)
                    ORG.pauseAvailable = true;

                ORG.pauseRace = false;
                pdiext::SetFrameModeLetterBox(false);
                context.getUpdateContext().zoom_for_SD = false;
                context.pushEvent(main::menu::MFunctionEvent(initialize_messenger, context));
            }
            else
            {
                ORG.pauseAvailable = false;
                ORG.pauseRace = false;
            }
        }

        if (Foot.visible)
        {
            if (gSequenceCondition.enable_director_command && !gSequenceCondition.is_buffer_replay_mode)
            {
                ROOT.setFocus(Foot::BSpec::Director);
                ORG.setBSpecCameraTable();
            }
            else
                ROOT.setFocus(Foot::Exit);
        }

        if (gSequenceCondition.is_buffer_replay_mode && gSequenceCondition.disable_replay_menu)
        {
            OnboardMeterRoot.visible = true;
            ORG.disp_meter = true;
        }

        if (main::GAME_STATUS.defined("branch"))
        {
            if (main::GAME_STATUS.branch.defined("camera_type"))
            {
                if (main::GAME_STATUS.branch.camera_type == main::gtengine::CameraType::WORLD_MOTION)
                    main::ORG.setWorldCameraMotion(main::GAME_STATUS.branch.mov_world_camera_ebc);

                if (main::GAME_STATUS.branch.camera_type == main::gtengine::CameraType::CAR_MOTION)
                    main::ORG.setCarCameraMotion(main::GAME_STATUS.branch.mov_car_camera_ebc);
            }
        }

        while (!ORG.inSession())
            pdistd::DelayThread(1000 * 100);

        while (!ORG.isRenderReady())
            pdistd::DelayThread(1000 * 100);

        while (!ORG.hasLoadingCarDone())
        {
            var loaded_num = ORG.getLoadedCarCount();
            pdistd::DelayThread(1000 * 100);
        }

        if (gSequenceCondition.game_mode == gtengine::GameMode::ONLINE_ROOM)
        {
            if (GAME_STATUS.user_profile.option.bot_on)
                BotUtil::begin(context);
        }
    }

    function initialize_messenger(context)
    {
        UIKitProject::MessengerRoot.setNoticeList(sNoticeList);
        UIKitProject::MessengerRoot.putLogs(context, 6);

        var X = (pdiext::MSystemConfiguration::is4x3()) ? 32 + 240 : 32;

        UIKitProject::MessengerRoot.open(context, X, 526, 444, 402);
        UIKitProject::MessengerRoot.enterPopupMode(context);
    }

    method on_failed_to_start_session(context)
    {
        quit(context);
    }

    method onFinalize(context)
    {
        if (gSequenceCondition.game_mode == gtengine::GameMode::ONLINE_ROOM)
        {
            if (GAME_STATUS.user_profile.option.bot_on)
                BotUtil::end();
        }

        if (sWatcher != nil)
        {
            WatcherUtil::Delete(sWatcher);
            sWatcher = nil;
        }

        if (sDemoCameraWatcher != nil)
        {
            WatcherUtil::Delete(sDemoCameraWatcher);
            sDemoCameraWatcher = nil;
        }

        sDriftSoundEffectHolder = nil;

        if (main::GAME_STATUS.defined("branch"))
        {
            if (main::GAME_STATUS.branch.defined("camera_type"))
            {
                if (main::GAME_STATUS.branch.camera_type == main::gtengine::CameraType::WORLD_MOTION)
                    ORG.clearWorldCameraMotion();

                if (main::GAME_STATUS.branch.camera_type == main::gtengine::CameraType::CAR_MOTION)
                    ORG.clearCarCameraMotion();
            }
        }

        if (gSequenceCondition.is_arena)
            ORG.bspec_dev_skill_gauge = false;

        if (PluginModule.defined("onRaceRootFinalize"))
            PluginModule::onRaceRootFinalize(context);

        ORG.disableRenderingRace();
        ORG.disableSoundingRace();
        LeaveDetectUtil::end(context);

        self.BalloonTip.reset_value(context);
        self.BalloonTip.visible = false;
        DialogUtil::cancelConfirmDialog(context);
        Foot.finalize(context);

        if (!context.getUpdateContext().zoom_for_SD)
        {
            pdiext::SetFrameModeLetterBox(true);
            context.getUpdateContext().zoom_for_SD = true;
        }

        self.removePauseMenu(context);
        main::ORG.clearEventCallback();
        SoundUtil::SetupSound(SoundUtil::SCENE_MENU);
        CursorProject::GTLogoTransition.setMarkVisible(true);

        main::pdistd::MGamePort::SetWheelAssignMode(main::pdistd::WheelAssignMode::SDK);
        UIKitProject::MessengerRoot.close(context);

        if (sViewChangeWatcher != nil)
        {
            WatcherUtil::Delete(sViewChangeWatcher);
            sViewChangeWatcher = nil;
        }
    }

    method onCancel(context)
    {
        if (RaceMenuUtil::activated() && gSequenceCondition.isASpecPlaying())
        {
            main::sound.play("cancel");
            RaceMenuUtil::setFocus(context, 0);
            closePauseMenu(context);
        }

        else if (!gSequenceCondition.disable_replay_menu)
        {
            main::sound.play("cancel");
            ROOT.setFocus(Foot::Exit);
        }

        return EVENTRESULT_FILTER;
    }

    method onTextInput(context, event)
    {
        if (event.text != "")
            main::sound.play("chat_trans");

        Lobby.sendRoomChatMessageAsync(event.text);
        return EVENTRESULT_STOP;
    }

    function StartChat(context, widget, pad)
    {
        if (!gSequenceCondition.is_online)
            return;

        if (sIsChatRestricted)
        {
            sCancelableDialogOpening = true;

            DialogUtil::openConfirmDialog(context, DialogUtil::ERROR, 
            context.translate(ROOT, "OnlineMessage", "UNABLE_TO_CHAT_DUE_TO_RESTRICTION"));

            sCancelableDialogOpening = false;
            return;
        }

        main::sound.play("ok");
        OnlineSession.updateMemberState(gtengine::RoomMemberState::Chat, true);

        if (widget != nil)
            ROOT.setFocus(widget);

        if (widget == nil && UIKitProject::MessengerRoot.defined('ChatInput'))
        {
            var chat_input = UIKitProject::MessengerRoot::ChatInput;

            var w = context.osk_display_width;
            var h = context.osk_display_height;
            var sx = chat_input.sx;
            var sw = chat_input.w;
            var sh = chat_input.h;

            if (w == 640 && h == 480)
            {
                chat_input.sx = 360;
                chat_input.w = 720;
                chat_input.h = 75;
            }

            chat_input.visible = !pad;
            OSKUtil::openChatDialog(context, PROJECT::ROOT::ChatInput, !pad);
            chat_input.visible = false;

            if (w == 640 && h == 480)
            {
                chat_input.sx = sx;
                chat_input.w = sw;
                chat_input.h = sh;
            }
        }
        else
        {
            var chat_input = PROJECT::ROOT::ChatInput;
            chat_input.visible = !pad;
            OSKUtil::openChatDialog(context, chat_input, !pad);
            chat_input.visible = false;
        }

        OnlineSession.updateMemberState(gtengine::RoomMemberState::Chat, false);
    }

    method onKeyPress(context, event)
    {
        if (isPhotoPreview)
        {
            if (event.keysym == CELL_PAD_CTRL_CROSS)
            {
                main::sound.play("next");
                savePhotoFile(context);
                backFromPreivew(context);
                isPhotoPreview = false;
            }

            else if (event.keysym == CELL_PAD_CTRL_CIRCLE)
            {
                main::sound.play("cancel");
                backFromPreivew(context);
                isPhotoPreview = false;
            }

            return EVENTRESULT_FILTER;
        }

        if (gSequenceCondition.isASpecPlaying())
        {
            if (RaceMenuUtil::activated())
            {
                if ((event.port_state & 0x10) == 0)
                {
                    var activate_chat = false;

                    if (event.keysym >= 32 && event.keysym <= 191)
                        activate_chat = true;

                    if (activate_chat)
                    {
                        StartChat(context, nil, false);
                        return EVENTRESULT_FILTER;
                    }
                }

                return EVENTRESULT_CONTINUE;
            }
            else
                return EVENTRESULT_FILTER;
        }
        else if (ORG.inSession())
        {
            if ((ROOT.sEnablePhoto || GetVersionBranch() == "academy") && context.active_root_transition == nil && event.keysym == CELL_PAD_CTRL_START)
            {
                main::sound.play("checkbox");

                if (ORG.pauseRace)
                    set_dt(1.0);
                else
                    set_dt(0.0);

                changePauseState(context);
                changeChapterState(context);
            }

            if (LeaveDetectUtil::activated(context, event))
                return EVENTRESULT_FILTER;

            if (gSequenceCondition.isDemo() && gSequenceCondition.disable_replay_menu)
            {
                var keyState = context.getUpdateContext().getPadButtonState(0);
                if (!ORG.isDebugStopFlag() && !(keyState & 0x1000) && event.keysym == CELL_PAD_CTRL_START)
                {
                    OnboardMeterRoot.visible = false;

                    if (PluginModule.defined("onFinishInstantReplay"))
                        PluginModule::onFinishInstantReplay(context);
                    else
                        self.quit(context);

                    return EVENTRESULT_FILTER;
                }
            }

            if (!gSequenceCondition.disable_replay_menu && !gSequenceCondition.is_online && event.keysym == PS2_PAD_CTRL_SELECT)
            {
                if (ORG.pauseRace || ORG.isTargetCarPitIn())
                {
                    main::sound.play("disable");
                    return EVENTRESULT_FILTER;
                }

                main::sound.play("cursor");
                ORG.callDriversViewChange();
                return EVENTRESULT_FILTER;
            }

            if (gSequenceCondition.is_online)
            {
                if ((event.keysym == PS2_PAD_CTRL_SELECT && gSequenceCondition.is_buffer_replay_mode) || 
                    (GAME_STATUS.user_profile.option.lounge_change_view && ORG.getCameraType() != gtengine::CameraType::PREVIEW))
                {
                    main::sound.play("cursor");
                    ORG.callDriversViewChange();
                    return EVENTRESULT_FILTER;
                }

                if ((event.port_state & 0x10) == 0)
                {
                    if (GAME_STATUS.user_profile.option.lounge_keyboard_switcher)
                        onKeyboardSwitcher(context, event);
                    else
                    {
                        if (!gSequenceCondition.is_buffer_replay_mode)
                        {
                            if (event.keysym >= 32 && event.keysym <= 191)
                            {
                                StartChat(context, Foot::ButtonChat, false);
                                return EVENTRESULT_FILTER;
                            }
                        }
                    }
                }
            }

            var is_ta = RaceOperator.race_parameter.race_type == main::gtengine::GameMode::TIME_ATTACK;

            if (is_ta && __projects__["RaceTimeAttackProject"] != nil && gSequenceCondition.is_logger_mode)
            {
                if (RaceTimeAttackProject::DataLoggerRoot.isActive())
                    RaceTimeAttackProject::DataLoggerRoot.onKeyPress(context, event);

                if ((event.state & 0x200) != 0)
                    return EVENTRESULT_FILTER;
            }

            return EVENTRESULT_CONTINUE;
        }      
    }

    function onTick(context)
    {
        if (!ROOT.visible)
            return;

        if (ROOT::Info::RemainTime.visible)
            Info::Winner.setWinnerAvatar(context);

        if (!RaceOperator.race_parameter.race_type == main::gtengine::GameMode::DRIFT_ATTACK)
            return;

        main::ORG.fetchRaceDisplay();

        var state = main::ORG.getRaceDisplayState(0);
        if (state.is_target_existing)
        {
            if (state.drift_section_max > 0)
            {
                if (sDriftFirstFrame)
                {
                    if (state.drift_section_state == 0)
                        sDriftFirstFrame = false;
                }
                else
                    onTickDrift(context);
            }
        }
    }

    function startMaxSpeedView(context)
    {
        if (gSequenceCondition.gp.event.game_mode != main::gtengine::GameMode::SPEED_TEST)
            return;

        var current_rp;
        if (gSequenceCondition.is_buffer_replay_mode)
            current_rp = main::ORG.getCurrentRaceParameter();
        else
            current_rp = main::ORG.getBackRaceParameter();

        if (!current_rp.endless)
        {
            Info::MaxSpeed.visible = false;
            return;
        }

        var is_mile = main::GAME_STATUS.user_profile.option.unit_velocity;
        Info::MaxSpeed::TextFace.text = is_mile ? "mph" : "km/h";

        Info::MaxSpeed.visible = true;
        sDriftBlinkNow = 0;
        sDriftScale = 1.5;
        sDriftPrevNoteRate = 0;
    }

    function onDemoCameraTick(context)
    {
        var racers_list = ORG.getCarOrderList();

        if (racers_list.size > 0)
        {
            if (racers_list.size == 1)
                ORG.setCameraTarget(0, racers_list[0]);
            else
            {
                var prev_target = ORG.getCameraTarget(0);
                var new_target = prev_target;

                do
                {
                    var new_target = pdistd::MRandom::GetValue(0, racers_list.size);
                } while (prev_target == new_target);

                ORG.setCameraTarget(0, racers_list[new_target]);
            }
        }
    }

    function appearDriftPanel()
    {
        var W = Info::DriftScore;
        W.visible = true;
        W.FadeInterpolator.reverse = true;
        W.FadeInterpolator.restart();
        W.VectorInterpolator.reverse = true;
        W.VectorInterpolator.restart();

        var color = main::menu::MColorObject(204.0 / 255, 211.0 / 255, 239.0 / 255, 1.0);
        W.SectionScore.base_color = color;
        W.SectionScoreAdd.base_color = color;
        W.SectionScore.visible = true;
        W.SectionScoreAdd.visible = true;
        W.Meter::blink.visible = false;
    }

    function disappearDriftPanel()
    {
        var state = main::ORG.getRaceDisplayState(0);
        var W = Info::DriftScore;

        W.FadeInterpolator.reverse = false;
        W.FadeInterpolator.restart();
        W.VectorInterpolator.reverse = false;
        W.VectorInterpolator.restart();

        var color = main::menu::MColorObject(236.0 / 255, 190.0 / 255, 5.0 / 255, 1.0);
        W.SectionScore.base_color = color;
        W.SectionScoreAdd.base_color = color;
        W.SectionScoreAdd::FadeInterpolator.reverse = true;
        W.SectionScoreAdd::FadeInterpolator.restart();
    }

    function driftScoreDecideAppear()
    {
        main::ORG.fetchRaceDisplay();
        var state = main::ORG.getRaceDisplayState(0);

        var W = Info::DriftScore;
        W.visible = false;
        W.ScalarInterpolator.restart();
        W.visible = true;
    }

    function checkTrophy(context)
    {
        if (!gSequenceCondition.is_buffer_replay_mode)
        {
            var slot_id = getPlayerSlot();
            if (slot_id < 0)
                return;

            main::ORG.fetchRaceDisplay();
            var state = ORG.getRaceDisplayState(0);

            var score = state.drift_best_score;
            checkTrophyGetMessage(context, score);
        }
    }

    function onTickDrift(context)
    {
        var state = main::ORG.getRaceDisplayState(0);
        var W = Info::DriftScore;
        var change_sector = false;

        if (sDriftOldState != state.drift_section_state && state.drift_section_state == 1)
        {
            appearDriftPanel();
            main::sound.play("point_reset", 0.5);

            sDriftBlinkNow = 0;
            sDriftScale = 1.5;
            sDriftPrevNoteRate = 0;
            change_sector = true;
            offVisibleFlag();
        }
        else if (sDriftOldState != state.drift_section_state && state.drift_section_state >= 2)
        {
            resetBlink();
            sDriftPrevNoteRate = 0;
            disappearDriftPanel();

            if (state.drift_section_grade == 0)
                main::sound.play("license_cursor");
            else
                main::sound.play("point4");

            switch (state.drift_section_grade)
            {
                case 4:
                    main::sound.play("big_cheer");
                    break;

                case 3:
                    main::sound.play("clap_b");
                    break;

                case 2:
                    main::sound.play("clap_m");
                    break;

                case 1:
                    main::sound.play("clap_s");
                    break;

                default:
                    main::sound.play("booing");
                    break;
            }

            sDriftScale = 1.5;
            change_sector = true;
            checkTrophy(context);
        }

        sDriftOldState = state.drift_section_state;
        var diff = sDriftOldScore - state.drift_section_score;

        if (diff < 0)
            diff *= -1.0;

        if (state.drift_section_score == 0 && diff > 0.0)
        {
            sDriftIntervalFrame = 0;
            sDriftScale = 1.5;
        }

        if (sDriftIntervalFrame <= 0 && diff > 0.0 && !change_sector)
        {
            if (state.drift_section_score == 0)
                main::sound.play("license_cursor");

            else
                main::sound.play("tab_switch");

            var add_rate = (diff * state.drift_section_immediate) / 10.0;
            sDriftScale += add_rate * 0.7;
            sDriftIntervalFrame = 11 - add_rate;

            if (sDriftIntervalFrame < 2)
                sDriftIntervalFrame = 2;

            if (sDriftScale > 1.5)
                sDriftScale = 1.5;

            W.SectionScoreAdd::FadeInterpolator.reverse = true;
            W.SectionScoreAdd::FadeInterpolator.restart();
        }

        else if (sDriftIntervalFrame > 0)
        {
            sDriftIntervalFrame -= 1;
        }

        sDriftScale += (0.9 - sDriftScale) * 0.1;

        W.SectionScore.scale_x = 0.9;
        W.SectionScore.scale_y = 0.9;
        W.SectionScoreAdd.scale_x = sDriftScale;
        W.SectionScoreAdd.scale_y = sDriftScale;

        sDriftOldScore = state.drift_section_score;
        onTickMeter(context);
    }

    function getAddFlag(num)
    {
        if (num < 0)
            num = 0;

        var id = num % 10;
        var W = Info::DriftScore::Meter::add;

        if (main::GAME_STATUS.config.drift_flag)
            W = Info::DriftScore::Meter::add_real;

        var list = [W.base0, W.base1, W.base2, W.base3, W.base4, W.base5, W.base6, W.base7, W.base8, W.base9];
        var flag = list[id];

        return flag;
    }

    function onFlag(num)
    {
        if (num > 9 && !main::GAME_STATUS.config.drift_flag_loop)
            return;

        if (num < 0)
            num = 0;

        var flag = getAddFlag(num);
        flag.visible = true;
        flag.VectorInterpolator.reverse = false;
        flag.VectorInterpolator.restart();
        flag.ScalarInterpolator.reverse = false;
        flag.ScalarInterpolator.restart();

        if (main::GAME_STATUS.config.drift_flag_loop)
        {
            var color0 = [255, 76, 76, 255];
            var color1 = [255, 235, 0, 255];
            var color2 = [157, 0, 157, 255];
            var col_list = [color0, color1, color2];

            var col_id = (num / 10.0) % 3;
            flag.face_color = col_list[col_id];
        }
        else
        {
            if (main::GAME_STATUS.config.drift_flag)
                return;

            var color0 = [255, 76, 76, 255];
            flag.face_color = color0;
        }

        var state = main::ORG.getRaceDisplayState(0);
    }

    function offFlag(num)
    {
        if (num > 9)
            return;

        if (num < 0)
            num = 0;

        var flag = getAddFlag(num);
        flag.VectorInterpolator.reverse = true;
        flag.VectorInterpolator.restart();

        if (!main::GAME_STATUS.config.drift_flag)
            flag.face_color = [255, 76, 76, 255];
    }

    function clearFlagColor()
    {
        if (main::GAME_STATUS.config.drift_flag)
            return;

        for (var id = 0; id < 10; id++)
        {
            var flag = getAddFlag(id);
            flag.face_color = [255, 76, 76, 255];
        }
    }

    function offVisibleFlag()
    {
        for (var id = 0; id < 10; id++)
        {
            var flag = getAddFlag(id);
            flag.visible = false;
        }
    }

    function resetBlink()
    {
        var WM = Info::DriftScore::Meter::blink;

        var list = [
            WM.base0, WM.base1, WM.base2, WM.base3, WM.base4, 
            WM.base5, WM.base6, WM.base7, WM.base8, WM.base9
        ];

        for (var id = 0; id < 10; id++)
        {
            var flag = list[id];
            flag.FaceColorInterpolator.restart();
        }
    }

    function onTickMeter(context)
    {
        var state = main::ORG.getRaceDisplayState(0);
        var score = state.drift_section_grade_rate * 10.0;
        var score = score.toInt();
        var W = Info::DriftScore::Meter;

        W.TextFace.text = state.drift_section_grade_rate * 10.0;
        W.TextFace0.text = score;
        W.TextFace1.text = sDriftPrevNoteRate;

        if (score >= sDriftPrevNoteRate + 1)
        {
            var prev = sDriftPrevNoteRate;

            while (prev < score)
            {
                onFlag(prev);
                prev++;
            }

            sDriftPrevNoteRate = score;

            if (score == 10)
                resetBlink();
        }

        if (score < sDriftPrevNoteRate && score < 10)
        {
            clearFlagColor();
            var prev = sDriftPrevNoteRate;

            if (prev > 9)
                prev = 9;

            while (prev >= score)
            {
                var id = prev % 10;
                offFlag(id);
                prev--;
            }

            sDriftPrevNoteRate = score;
        }

        if (score >= 10 || (state.drift_section_state >= 2 && state.drift_section_grade != 0))
            W.Meter::blink.visible = true;
        else
            W.Meter::blink.visible = false;
    }

    method process_after_session(context)
    {
        if (PluginModule.defined("onAfterSession"))
            PluginModule::onAfterSession(context);

        writebackParameter();
        checkTrophyAfterRace(ROOT.sLastConditionSatisfied);
    }

    method quit(context, result_entry_list)
    {
        if (sAlreadyQuited)
            return false;
        else
            sAlreadyQuited = true;

        SoundUtil::BGMFadeout(1.0);
        ORG.getRaceSound().start = false;

        if (context.active_root_transition == nil)
        {
            SequenceUtil::setupTransition(context, CursorProject::ColorTransition);
            context.pageOutRootTransition();
            context.syncOutRootTransition();
        }

        QuickOptionRoot.abort(context);

        if (ROOT::Foot.current_view != nil)
            ROOT::Foot.current_view.finalize(context);

        if (!gSequenceCondition.disable_end_session)
        {
            main::ORG.endSession();
            self.process_after_session(context);
        }

        if (PluginModule.defined("onQuitRace"))
            PluginModule::onQuitRace(context);

        main::ORG.clearEventCallback();
        main::ORG.pauseRace = true;
        context.wait(0.1);

        var is_ta = RaceOperator.race_parameter.race_type == gtengine::GameMode::TIME_ATTACK;
        if (is_ta && gSequenceCondition.is_buffer_replay_mode && gSequenceCondition.is_logger_mode)
        {
            var datalogger = main::gtengine::MDataLogger();
            datalogger.resetRaceControl();
            datalogger.endLoggerData();
        }

        if (PluginModule.defined("onAfterRace"))
            PluginModule::onAfterRace(context);

        main::ORG.pauseRace = false;

        if (PluginModule.defined("onGoToNextSequence"))
            PluginModule::onGoToNextSequence(context);
        else
        {
            if (gSequenceCondition.quick_root != nil)
                gSequenceCondition.quick_root.open(context);
            else
                goToMenuSequence(context);
        }

        return true;
    }

    method quit_and_goto_top(context, result_entry_list)
    {
        if (sAlreadyQuited)
            return;
        else
            sAlreadyQuited = true;

        main::ORG.clearEventCallback();
        SoundUtil::BGMFadeout(1.0);
        ORG.getRaceSound().start = false;

        if (!gSequenceCondition.disable_end_session)
        {
            main::ORG.endSession();
            self.process_after_session(context);
        }

        if (PluginModule.defined("onQuitRace"))
            PluginModule::onQuitRace(context);

        main::ORG.pauseRace = true;
        context.wait(0.1);

        if (PluginModule.defined("onAfterRace"))
            PluginModule::onAfterRace(context);

        main::ORG.pauseRace = false;
        goToMenuSequence(context);
    }

    method activatePauseMenu(context)
    {
        RaceMenuUtil::enableFocus(context);
        RaceMenuUtil::resetCloseAction(context);
        RaceMenuUtil::setFocus(context, 0);
        context.cursor_visible = true;
        RaceMenuUtil::appearAction();
    }

    method deactivatePauseMenu(context)
    {
        context.cursor_visible = false;
        RaceMenuUtil::hideAction();
        resetFocus(ROOT);
        RaceMenuUtil::disableFocus(context);
    }

    method activateFoot(context)
    {
        context.cursor_visible = true;
        Foot::ScalarInterpolator.reverse = false;
        Foot::ScalarInterpolator.start();
        Head::ScalarInterpolator.reverse = false;
        Head::ScalarInterpolator.start();

        if (Foot.current_view != nil && LTBase["View"] != nil && Foot.current_view.View.defined("activateMenu"))
            LTBase.View.activateMenu(context);

        ORG.disp_meter = false;
        changeChapterState();
    }

    method deactivateFoot(context, warp)
    {
        if (!(gSequenceCondition.enable_director_command && !gSequenceCondition.is_buffer_replay_mode))
        {
            context.cursor_visible = false;

            Foot::ScalarInterpolator.reverse = true;
            if (warp != nil && warp)
                Foot::ScalarInterpolator.warp();
            else
                Foot::ScalarInterpolator.start();

            Head::ScalarInterpolator.reverse = true;
            if (warp != nil && warp)
                Head::ScalarInterpolator.warp();
            else
                Head::ScalarInterpolator.start();
        }

        if (Foot.current_view != nil && LTBase["View"] != nil && Foot.current_view.View.defined("deactivateMenu"))
            LTBase.View.deactivateMenu(context, warp);
    }

    method activateMenuForRealEvent(context)
    {
        context.cursor_visible = true;
        Foot::ScalarInterpolator.reverse = false;
        Foot::ScalarInterpolator.start();

        if (Foot.current_view != nil && LTBase["View"] != nil && Foot.current_view.View.defined("activateMenuForRealEvent"))
            LTBase.View.activateMenuForRealEvent(context);
    }

    method deactivateMenuForRealEvent(context, warp)
    {
        if (!(gSequenceCondition.enable_director_command && !gSequenceCondition.is_buffer_replay_mode))
        {
            context.cursor_visible = false;
            Foot::ScalarInterpolator.reverse = true;

            if (warp != nil && warp)
                Foot::ScalarInterpolator.warp();
            else
                Foot::ScalarInterpolator.start();
        }

        if (Foot.current_view != nil && LTBase["View"] != nil && Foot.current_view.View.defined("deactivateMenuForRealEvent"))
            LTBase.View.deactivateMenuForRealEvent(context, warp);
    }

    method changeChapterState(context)
    {
        if (ORG.canSeekNextChapter() == true)
            Foot::GotoNext.active = true;
        else
            Foot::GotoNext.active = false;

        if (ORG.canSeekPrevChapter() == true)
            Foot::GotoBack.active = true;
        else
            Foot::GotoBack.active = false;
    }

    method changePauseState(context, sound = true)
    {
        if (gSequenceCondition.enable_director_command && !gSequenceCondition.is_buffer_replay_mode)
            return;

        context.sync(0.1);
        var pause = main::ORG.pauseRace;

        if (GetVersionBranch() != "academy")
        {
            if (!pause)
            {
                disappearPhoto(context);

                if (LeaveDetectUtil::isSuspend())
                    LeaveDetectUtil::resume(context);
            }
            else
            {
                if (!gSequenceCondition.is_logger_mode)
                    appearPhoto(context);

                if (!LeaveDetectUtil::isSuspend())
                    LeaveDetectUtil::suspend(context);
            }
        }

        ORG.getRaceSound().start = !pause;

        if (sound)
        {
            SoundUtil::BGMPause(pause);
            SoundUtil::PauseStream(pause);
        }
    }

    method appearPhoto(context)
    {
        Foot::PauseAndPhoto.active = true;
        Foot::PauseAndPhoto::label.visible = false;
        Foot::PauseAndPhoto::label_only_pause.visible = false;
        Foot::PauseAndPhoto::label_exit.visible = true;
        sPrevIsPitIn = false;
        var disable_photo = false;

        if (ORG.isTargetCarPitIn())
        {
            sPrevIsPitIn = true;
            var camnum = ORG.getTargetCarDistributeCameraNum();

            if (camnum <= 0)
                disable_photo = true;
        }

        Foot::GotoHead.can_focus = true;
        Foot::GotoHead::ScalarInterpolator.reverse = false;
        Foot::GotoHead::ScalarInterpolator.start();
        Foot::GotoHead.visible = gSequenceCondition.repeat_replay;

        if (ORG.canSkipChapter() && ORG.isLicenseCameraTable() == false)
        {
            Foot::GotoBack.can_focus = true;
            Foot::GotoBack::ScalarInterpolator.reverse = false;
            Foot::GotoBack::ScalarInterpolator.start();

            Foot::GotoBack.visible = true;
            Foot::GotoNext.can_focus = true;
            Foot::GotoNext::ScalarInterpolator.reverse = false;
            Foot::GotoNext::ScalarInterpolator.start();
            Foot::GotoNext.visible = true;
        }
        else
        {
            Foot::GotoBack.visible = false;
            Foot::GotoNext.visible = false;
        }

        if (!Foot::Button::ViewFull.active || disable_photo)
        {
            Foot::PhotoButton::HBox::Photo.insensitive = true;
            Foot::PhotoButton::HBox::EasyPhoto.insensitive = true;
            Foot::PhotoButton::HBox::Photo::ScalarInterpolator.reverse = true;
            Foot::PhotoButton::HBox::Photo::ScalarInterpolator.start();
            Foot::PhotoButton::HBox::EasyPhoto::ScalarInterpolator.reverse = true;
            Foot::PhotoButton::HBox::EasyPhoto::ScalarInterpolator.start();

            return;
        }

        Foot::PhotoButton::HBox::Photo::ScalarInterpolator.reverse = false;
        Foot::PhotoButton::HBox::Photo::ScalarInterpolator.start();
        Foot::PhotoButton::HBox::Photo.insensitive = false;
        Foot::PhotoButton::HBox::EasyPhoto.insensitive = true;

        Foot::PhotoButton::HBox::Photo.visible = true;
        Foot::PhotoButton::HBox::EasyPhoto.visible = false;
    }

    method disappearPhoto(context)
    {
        Foot::PauseAndPhoto.active = false;

        if (Foot::Button::ViewFull.active)
        {
            Foot::PauseAndPhoto::label.visible = true;
            Foot::PauseAndPhoto::label_only_pause.visible = false;
        }
        else
        {
            Foot::PauseAndPhoto::label.visible = false;
            Foot::PauseAndPhoto::label_only_pause.visible = true;
        }

        Foot::PauseAndPhoto::label_exit.visible = false;
        Foot::PhotoButton::HBox::Photo.insensitive = true;
        Foot::PhotoButton::HBox::EasyPhoto.insensitive = true;

        Foot::PhotoButton::HBox::Photo::ScalarInterpolator.reverse = true;
        Foot::PhotoButton::HBox::Photo::ScalarInterpolator.start();
        Foot::PhotoButton::HBox::EasyPhoto::ScalarInterpolator.reverse = true;
        Foot::PhotoButton::HBox::EasyPhoto::ScalarInterpolator.start();

        if (ROOT.focus_widget == Foot::PhotoButton::HBox::Photo || 
            ROOT.focus_widget == Foot::PhotoButton::HBox::EasyPhoto)
        {
            ROOT.setFocus(Foot::Exit);
        }
    }

    method closePauseMenu(context)
    {
        main::ORG.pauseHandleAvailable = false;
        RaceMenuUtil::closeAction(context);

        Foot::ScalarInterpolator.reverse = true;
        Foot::ScalarInterpolator.start();
        Head::ScalarInterpolator.reverse = true;
        Head::ScalarInterpolator.start();

        OSKUtil::closeChatDialog(context);
        main::ORG.pauseRace = false;
        OnboardMeterRoot.appearPanel();

        resetFocus(ROOT);
        SoundUtil::BGMPause(false);
        main::ORG.pauseHandleAvailable = true;

        if (PluginModule.defined("onClosePauseMenu"))
            PluginModule::onClosePauseMenu(context);
    }

