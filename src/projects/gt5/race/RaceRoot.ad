    module Info::Winner
    {
        attribute winner_dp;

        method setWinnerAvatar(context)
        {
            if (gSequenceCondition.game_mode != gtengine::GameMode::ONLINE_ROOM && 
                gSequenceCondition.game_mode != gtengine::GameMode::ARENA)
                return;

            if (self.winner_dp != nil)
                return;

            var entry_list = ResultRoot.getEntryList();
            if (entry_list.size <= 0 || entry_list[0] == nil || entry_list[0].dp == nil)
                return;

            self.FadeActor.reset();
            self.visible = true;
            var dp = entry_list[0].dp;
            self.winner_dp = dp;

            self.Name.label.text = dp.display_name;
            self.Name.labela.text = self.Name.label.text;
            self.Name.active = entry_list[0].cp.target;

            var head_code = dp.head_code;
            var head_color_code = dp.head_color_code;
            var body_code = dp.body_code;
            var body_color_code = dp.body_color_code;
            var w = self.ImageFaceCombo;

            var head_load_complete = method (context) {
                ImageFaceCombo::Head.on_delay_load_complete = nil;

                if (ImageFaceCombo::Body.on_delay_load_complete == nil)
                    Info::Winner.FadeActor.start();
            };

            var body_load_complete = method (context) {
                ImageFaceCombo::Body.on_delay_load_complete = nil;

                if (ImageFaceCombo::Head.on_delay_load_complete == nil)
                    Info::Winner.FadeActor.start();
            };

            w.Head.on_delay_load_complete = self.*head_load_complete;
            w.Body.on_delay_load_complete = self.*body_load_complete;

            w.Head.image_path = ThumbnailUtil::Avatar::getImagePath(
                ThumbnailUtil::Avatar::Genre::COMBO, ThumbnailUtil::Avatar::Type::MET, 
                "M", 
                head_code, head_color_code, 
                body_code, body_color_code
            );

            w.Body.image_path = ThumbnailUtil::Avatar::getImagePath(
                ThumbnailUtil::Avatar::Genre::COMBO, ThumbnailUtil::Avatar::Type::SUITS, 
                "M", 
                head_code, head_color_code, 
                body_code, body_color_code
            );
        }
    }
}