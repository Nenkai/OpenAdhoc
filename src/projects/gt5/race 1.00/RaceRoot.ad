        module PhotoButton::HBox::EasyPhoto
        {
            method onFocusEnter(context)
            {
                ROOT.BalloonTip.visible = false;
                ROOT.BalloonTip.reset_value(context);
                return EVENTRESULT_FILTER;
            }

            method onActivate(context)
            {
                if (Foot::PauseAndPhoto.active)
                {
                    var space = pdistd::GetDiskFreeSize("/APP_DATA");

                    if (space < (10 * 1024) * 1024)
                    {
                        main::sound.play("disable");
                        DialogUtil::openConfirmDialog(context, DialogUtil::ERROR, 
                        context.translate(ROOT, "SystemMessage", "DISKFULL").build("10MB"));

                        return EVENTRESULT_FILTER;
                    }

                    main::sound.play("shutter00");
                    return onEasyPhoto(context);
                }

                return EVENTRESULT_FILTER;
            }
        }

