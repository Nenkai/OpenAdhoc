    function resetPlayerSettings()
    {
        main::GAME_STATUS.user_profile.context.driving_line = true;
        var new_cp = main::gtengine::MCarParameter(getPlayerCar().getCarCode());
        new_cp.color = getPlayerCar().color;

        var new_dp = main::gtengine::MCarDriverParameter();
        new_dp.setPlayer(0);
        new_dp.display_driving_line = true;

        var cons = gSequenceCondition.gp.event.constraint;
        var res = cons.checkIfQualified(new_cp, [new_dp]);

        if (res[0])
            ;
        else
        {
            |var apply_cp, var apply_dp_list| = cons.apply(new_cp, new_dp);
            new_cp = apply_cp;
            new_dp = apply_dp_list[0];
        } 
        
        main::RaceOperator.setTargetCarParameter(0, new_cp);
        main::RaceOperator.setTargetDriverParameter(0, 0, new_dp);
    }

    function restrictRTA(quicktune_available)
    {
        if (!quicktune_available)
        {
            var dp = getPlayerDriver();
            if (dp != nil)
                dp.setRTAUnadjustable(main::gtengine::RTAType::AWD | main::gtengine::RTAType::ABS | main::gtengine::RTAType::BRK_FR);
        }
