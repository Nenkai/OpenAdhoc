                    }
                }
            }

            module Chat
            {
                method initialize(context, popup)
                {
                    UIKitProject::MessengerRoot.setNoticeList(sNoticeList);

                    if (popup)
                    {
                        var X = pdiext::MSystemConfiguration::is4x3() ? 32 + 240 : 32;

                        UIKitProject::MessengerRoot.open(context, X, 526, 444, 402, false);
                        UIKitProject::MessengerRoot.putLogs(context, 6);
                        UIKitProject::MessengerRoot.enterPopupMode(context);
                    }
                    else
                    {
                        var x = 20;
                        var y = 438;

                        UIKitProject::MessengerRoot.open_cascade(context, CascadeRoot, true, x, y, CascadeRoot.w, CascadeRoot.h);

                        UIKitProject::MessengerRoot.putLogs(context, 6);
                        UIKitProject::MessengerRoot.enterChatMode(context);
                    }
                }

                method finalize(context)
                {
                    UIKitProject::MessengerRoot.close(context);
                }

                method activate(context)
                {
                    finalize(context);
                    initialize(context, false);
                }

                method deactivate(context)
                {
                    finalize(context);
                    initialize(context, true);
                }
            }

            module Tab
            {
                module Map
                {
                    method onActivate(context)
                    {
                        if (Tab.active)
                        {
                            main::sound.play("cursor");
                            MapChatTabChat = false;
                            Tab.active = MapChatTabChat;

                            MapChatPane.Map.visible = !Tab.active;
                            MapChatPane.Chat.visible = Tab.active;
                        }

                        return EVENTRESULT_FILTER;
                    }
                }

                module Chat
                {
                    method onActivate(context)
                    {
                        if (!Tab.active)
                        {
                            main::sound.play("cursor");
                            MapChatTabChat = true;
                            Tab.active = MapChatTabChat;

                            MapChatPane.Map.visible = !Tab.active;
                            MapChatPane.Chat.visible = Tab.active;
                        }

                        return EVENTRESULT_FILTER;
                    }
                }
            }
        }

        module RacerPane
        {
            Head.UserID.label.localized_text_page = "RaceProject::LiveTimingRoot";
            Head.Car.label.localized_text_page = "RaceProject::LiveTimingRoot";

            attribute fixed_items;
            attribute items;

            method initialize(context)
            {
                Head.UserID.active = !GAME_STATUS.user_profile.option.racer_list_car;
                Head.Car.active = GAME_STATUS.user_profile.option.racer_list_car;

                var base_y = Head.h;
                var step_y = hidden::RacerItem.h;

                self.fixed_items = Array(16);

                for (var i = 0; i < 16; i++)
                {
                    var item = hidden::FixedItem.doCopy();

                    item.x = 0;
                    item.y = item.h * i;
                    item.order = i;

                    if (i == (16 - 1))
                    {
                        item.removeChild(context, item.line);
                    }

                    Base.appendChild(context, item);
                    item.No.label.text = "";
                    self.fixed_items[i] = item;
                }

                self.items = Array(16);

                for (var i = 0; i < 16; i++)
                {
                    var item = hidden::RacerItem.doCopy();

                    item.x = 0.0;
                    item.y = base_y + (step_y * i);

                    item.ChaseActor.is_interpolate_mode = true;
                    item.ChaseActor.freeze();

                    item.label.text = "";
                    item.active = false;
                    item.camtarget.visible = false;

                    self.appendChild(context, item);
                    self.items[i] = item;
                }
            }

            method finalize(context)
            {
                Base.clearChildren(context);

                if (self.items != nil)
                {
                    foreach (var w in self.items)
                        self.removeChild(context, w);

                    self.items = nil;
                }

                self.fixed_items = nil;
            }

            method refresh(context, entry_max, report, racers_list, warp, move_index_list)
            {
                var base_y = Head.h;
                var step_y = hidden:: RacerItem.h;
                var racers_num = racers_list.size;

                var camera_target = ORG.getCameraTarget(0);
                var player_slot = RaceOperator.getPlayerSlot();
                var index;

                for (var i = 0; i < 16; i++)
                {
                    var fixed_item = self.fixed_items[i];

                    if (i < racers_num)
                        fixed_item.No.label.text = (i + 1).toString();
                    else
                        fixed_item.No.label.text = "";

                    fixed_item.visible = (i < racers_num);

                    var item = self.items[i];
                    if (warp)
                        index = i;
                    else
                        index = move_index_list[i];

                    if (index < racers_num && racers_list[index] >= 0)
                    {
                        var slot_id = racers_list[index];
                        item.active = (player_slot == slot_id);

                        if (Head.UserID.active)
                        {
                            if (gSequenceCondition.display_entry_name)
                                item.label.text = "%{report.display_name[slot_id]}/%{report.entry_name[slot_id]}";
                            else
                                item.label.text = report.display_name[slot_id];
                        }

                        else if (Head.Car.active)
                        {
                            var code = report.current_car_code[slot_id];
                            var cp = ORG.getEntriedCarParameter(slot_id);

                            if (cp != nil)
                                code = cp.getCarCode();

                            var car_name = gtengine::MSpecDB::getCarName(code);
                            item.label.text = car_name;
                        }

                        item.camtarget.visible = camera_target == slot_id;
                        item.visible = true;
                    }
                    else
                    {
                        item.active = false;
                        item.label.text = "";
                        item.visible = false;
                    }

                    item.labela.text = item.label.text;

                    if (warp)
                    {
                        item.y = base_y + (step_y * index);
                        item.ChaseActor.reset();
                    }
                    else
                        item.ChaseActor.target_y = base_y + (step_y * index);
                }
            }

            module Head
            {
                module Car
                {
                    method onActivate(context)
                    {
                        if (!self.active)
                        {
                            main::sound.play("cursor");
                            GAME_STATUS.user_profile.option.racer_list_car = true;

                            self.active = true;
                            UserID.active = false;
                        }

                        return EVENTRESULT_FILTER;
                    }
                }

                module UserID
                {
                    method onActivate(context)
                    {
                        if (!self.active)
                        {
                            main::sound.play("cursor");
                            GAME_STATUS.user_profile.option.racer_list_car = false;

                            self.active = true;
                            Car.active = false;
                        }

                        return EVENTRESULT_FILTER;
                    }
                }
            }
        }
    }

    module hidden
    {
        module FixedItem
        {
            attribute order;

            method onActivate(context)
            {
                var racers_list = ORG.getCarOrderList();

                if (self.order >= racers_list.size)
                {
                    main::sound.play("disable");
                    return EVENTRESULT_FILTER;
                }

                var slot_id = racers_list[self.order];
                if (slot_id >= 0 && ORG.getEntryState(slot_id) == gtengine::EntryLevel::RACER)
                {
                    main::sound.play("ok");
                    ORG.setCameraTarget(0, slot_id);
                    RaceRoot.Foot.refresh(context);
                }
                else
                    main::sound.play("disable");

                return EVENTRESULT_FILTER;
            }
        }
    }
}