    method onStartSession(context)
    {
        ORG.setApplicationEndSessionSecond(gSequenceCondition.time_limit_second);
        var rp = main::ORG.getBackRaceParameter();
        OnboardMeterRoot.setRaceParameter(rp);
        removePauseMenu(context);
        createPauseMenu(context);
        changePauseState(context);

        if (RaceOperator.window_max >= 2)
        {
            ORG.noDispBackMirror(true);
        }

        else
        {
            ORG.noDispBackMirror(false);
        }

        if (rp.start_type == main::gtengine::StartType::GRID_FLYING)
        {
            Info::WarningMessage.visible = true;
            Info::WarningMessage::FadeInterpolator.restart();

            Info::WarningMessage::box::TextFace.text = context.translate(ROOT, "RaceProject::OnboardMeterRoot", "Penalty_Warning");
        }

        else
        {
            Info::WarningMessage.visible = false;
        }

        if (!gSequenceCondition.is_logger_mode)
        {
            ORG.pauseRace = false;
        }

        else
        {
            ROOT.replayStartByPauseState(context);
        }

        Foot.refresh(context);
    }

    method replayStartByPauseState(context)
    {
        set_dt(1.0);
        pdistd::DelayThread(0x3E8 * 0x32);
        set_dt(0.0);
    }

    method onRestartSession(context)
    {
        ORG.pauseHandleAvailable = false;
        SoundUtil::BGMStop();
        main::sound.play("ok");
        RaceMenuUtil::closeAction(context);
        ROOT.restart(context);
    }

