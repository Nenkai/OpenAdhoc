



module RaceRoot
{
    hidden.visible = false;
    static sHeadCar = false;
    static sViewChangeWatcher = nil;

    function view_change_tick(context)
    {
        ORG.callDriversViewChange();
    }

    method onUnload(context)
    {
        ORG.window_max = 1;
    }

    attribute sAlreadyQuited = false;
    attribute sNormalFinish = false;
    attribute sLastConditionSatisfied = false;
    attribute sEnablePhoto = false;
    static isPhotoPreview = false;
    attribute sBGMPlayFlags = 0;

    static sBGMPlayTypeMap = [
        gtengine::StartType::GRID : 1 | 4,
        gtengine::StartType::ROLLING : 2,
        gtengine::StartType::PIT : 2,
        gtengine::StartType::ATTACK : 4,
        gtengine::StartType::DISPERSED : 2,
        gtengine::StartType::COURSEINFO : 2,
        gtengine::StartType::ROLLING2 : 2,
        gtengine::StartType::SAMEGRID : 2,
        gtengine::StartType::ROLLING3 : 2,
        gtengine::StartType::COURSEINFO_ROLLING : 2,
        gtengine::StartType::STANDING : 4,
        gtengine::StartType::ROLLING_NOLIMIT : 2,
        gtengine::StartType::FREE : 2,
        gtengine::StartType::STANDING_L : 4,
        gtengine::StartType::STANDING_R : 4,
        gtengine::StartType::PITWORK : 2,
        gtengine::StartType::ROLLING_DL : 4,
        gtengine::StartType::ROLLING_DR : 4,
        gtengine::StartType::GRID_FLYING : 2,
        gtengine::StartType::PITIN : 2,
        gtengine::StartType::RALLY : 4
    ]

    method setTarget(target, window_id)
    {
        if (window_id == nil)
            var window_id = 0;

        main::ORG.setCameraTarget(window_id, target);
        main::ORG.setRaceDisplayTarget(window_id, target);    
    }

    method getTarget(window_id)
    {
        if (window_id == nil)
            var window_id = 0;

        return main::ORG.getCameraTarget(window_id);    
    }

    method onLeaveDetectToQuit(context)
    {
        self.quit_and_goto_top(context);
    }

    function Go_Message(toinit)
    {
        var W = Info::Go;
        W.visible = false;

        if (toinit == true)
        {
            W.ScalarInterpolator.restart();
            W.VectorInterpolator.restart();
            W.ImageFace0::ScalarInterpolator.restart();
            W.visible = true;
        }
    }

    function GoalMessage(finish, win, lose, succ, disq)
    {
        var W = Info::Goal;
        W.visible = false;

        if (finish || win || lose || succ || disq)
        {
            W.ScalarInterpolator.restart();
            W.VectorInterpolator.restart();

            W.Finish.visible = finish;
            W.FinishFlash.visible = finish;
            W.FinishFlash::ScalarInterpolator.restart();

            W.Win.visible = win;
            W.Lose.visible = lose;
            W.Success.visible = succ;
            W.Disqualify.visible = disq;
            W.visible = true;
        }
    }

    method resetDisplay(context)
    {
        ROOT.visible = true;
        Info::CountDown.visible = false;
        Go_Message(false);
        Info::TimeUp::ScalarInterpolator.reset();

        GoalMessage(false, false, false, false, false);
        Info::ReplayResult.visible = false;
        Info::ReplayResult::ScalarInterpolator.reset();

        Info::NextEnemy.visible = false;
        Info::OvertakeResult.visible = false;
        Info::Infomation.visible = true;
        Info::Infomation::ReplayEnd.visible = false;
        Info::Infomation::NextlapInvalid.visible = false;
        Info::Infomation::TempRanking.visible = false;

        Info::Infomation::StartAtControlLine.visible = false;
        Info::Infomation::AutoDrive.visible = false;
        Info::CourseAnnounce.visible = false;
        Foot::MessageWindow.visible = false;
        Foot::PhotoButton::HBox::Photo.visible = false;
        Foot::PhotoButton::HBox::EasyPhoto.visible = false;

        var assign = main::pdiext::MSystemConfiguration::GetEnterButtonAssign();
        var button_circle = true;

        if (assign != "circle")
            var button_circle = false;

        AfterShootingHelp.visible = false;
        AfterShootingHelp::Pane::Buttons::Save::Circle.visible = button_circle;
        AfterShootingHelp::Pane::Buttons::Save::Cross.visible = !button_circle;
        AfterShootingHelp::Pane::Buttons::Back::Circle.visible = !button_circle;
        AfterShootingHelp::Pane::Buttons::Back::Cross.visible = button_circle;
        
        OnboardMeterRoot.appearPanel();
        OnboardMeterRoot::RaceDisplayFace.setOnlineRecord(0);
        OnboardMeterRoot::RaceDisplayFace.setMyOnlineRecord(0);

        if (gSequenceCondition.is_buffer_replay_mode)
            OnboardMeterRoot::RaceDisplayFace.setRemainMaxTime(0);

        else
            OnboardMeterRoot::RaceDisplayFace.setRemainMaxTime(((1000 * 60) * 1000) - 1);   
    }

    method onInitialize(context)
    {
        ORG.setEventCallback(context, ROOT);
        self.createPauseMenu(context);

        ORG.pauseHandleAvailable = false;
        ORG.pauseAvailable = false;
        main::ORG.window_max = main::RaceOperator.window_max;

        self.sAlreadyQuited = false;
        resetDisplay(context);
        gSequenceCondition.is_riding_car = true;
        var event = gSequenceCondition.gp.event;

        if (event.eval_condition.type == main::gtengine::EvalType::VS_GHOST)
        {
            Info::ReplayResult.visible = true;
            Info::ReplayResult::ScalarInterpolator.restart();

            Info::ReplayResult::Record::HBox::record.text = main::pdiext::GetRaceTimeString(event.eval_condition.gold);
            Info::ReplayResult::Record::HBox::unit.text = "";
            Info::ReplayResult::PlayerName.text = event.information.one_line_title.getText();
            Info::ReplayResult::PlayerName.visible = true;
        }

        OnboardMeterRoot.setRaceParameter(main::ORG.getBackRaceParameter());
        Head::RaceHeadrFace.begin4headlap(main::ORG, Head);
        Head::Current.translate_x = 0;
        Info::WarningMessage.visible = false;

        if (PluginModule.defined("onBeforeSession"))
        {
            PluginModule::onBeforeSession(context);
        }

        if (!gSequenceCondition.disable_start_session)
        {
            var start_session_success = gSequenceCondition.startSessionForRace();

            if (!start_session_success)
                context.pushEvent(main::menu::MScriptEvent(context, self, "on_failed_to_start_session"));
                return;
        }

        if (gSequenceCondition.isASpecPlaying() && GAME_STATUS.user_profile.option.timeout_count_to_topmenu > 0 
        && !gSequenceCondition.is_online)
        {
            LeaveDetectUtil::begin(context, main::GAME_STATUS.user_profile.option.timeout_count_to_topmenu, self, self.onLeaveDetectToQuit, nil);
        }

        var is_ta = RaceOperator.race_parameter.race_type == main::gtengine::GameMode::TIME_ATTACK;

        if (is_ta && gSequenceCondition.is_buffer_replay_mode && gSequenceCondition.is_logger_mode)
        {
            var head_buf = ORG.getReplayHeaderFromPath(ORG.replay_work_path);
            var info = gtengine::MReplayInfo();
            var success = info.initialize(head_buf);
            var stream_file = pdistd::GetFileStatus(ORG.replay_work_path);

            var total_size = stream_file["size"];
            var datalogger = gtengine::MDataLogger();
            datalogger.setRaceControl(ORG);

            var result = datalogger.beginLoggerData(ORG.replay_work_path, head_buf, total_size, 0, false);
            set_dt(0.0);
        }

        if (!gSequenceCondition.isDemo())
        {
            for (var i = 0; i < main::RaceOperator.window_max; i++)
            {
                var slot_id = RaceOperator.getPlayerSlot(i);
                setTarget(slot_id, i);
            }
        }

        Foot.initialize(context);
        self.BalloonTip.initialize(context)
        self.BalloonTip.visible = false;

        SoundUtil::SetupSound(
        (gSequenceCondition.isDemo() ? ((gSequenceCondition.is_with_na) ? SoundUtil::SCENE_REPLAY_WITH_NA : SoundUtil::SCENE_REPLAY) 
        : SoundUtil::SCENE_RACE)
        );

        if (!gSequenceCondition.isDemo())
        {
            var rp = main::ORG.getCurrentRaceParameter();
            var flags = sBGMPlayTypeMap[rp.start_type];

            if (flags == nil)
                var flags = 0;

            if (flags & 1)
            {
                if (rp.time_to_start < 12 * 1000)
                    flags &= ~1;
            }
            
            self.sBGMPlayFlags = flags;
        }

        else
        {
            self.sBGMPlayFlags = 2;
        }

        if (gSequenceCondition.is_online && self.sBGMPlayFlags & 2)
            self.sBGMPlayFlags = 8;

        if (self.sBGMPlayFlags & 8)
        {
            SoundUtil::BGMPlayGroup(
            (gSequenceCondition.isDemo() ? ((gSequenceCondition.is_with_na) ? SoundUtil::SCENE_REPLAY_WITH_NA : SoundUtil::SCENE_REPLAY) 
            : SoundUtil::SCENE_RACE), "racing", nil, 0.0, 3.0);
        }
        
        ROOT.visible = true;
        OnboardMeterRoot.visible = true;
        ORG.enableRenderingRace();

        if (is_ta && gSequenceCondition.is_buffer_replay_mode && gSequenceCondition.is_logger_mode)
        {
            ORG.disableSoundingRace();
            ORG.getRaceSound().start = false;
        }

        else
        {
            ORG.enableSoundingRace();
            ORG.getRaceSound().start = true;
        }

        if (PluginModule.defined("onRaceRootInitialize"))
            PluginModule::onRaceRootInitialize(context, ROOT);

        ORG.setEventSignalWait(false);
        resetFocus(ROOT);
        ROOT.sNormalFinish = false;
        ROOT.sLastConditionSatisfied = false;
        
        if (AppOpt.defined("autorun_viewchange"))
            sViewChangeWatcher = WatcherUtil::Create(context, view_change_tick, 60 * 5);

        if (RaceOperator.isTheater() || gSequenceCondition.is_logger_mode || gSequenceCondition.is_buffer_replay_mode)
        {
            if (gSequenceCondition.is_logger_mode)
            {
                ROOT.replayStartByPauseState(context);
                ORG.pauseRace = true;
            }

            else
            {
                ORG.pauseRace = false;
            }
        }
        
        else
        {
            if (gSequenceCondition.isASpecPlaying())
            {
                ORG.pauseHandleAvailable = true;
                ORG.pauseAvailable = true;
                ORG.pauseRace = false;
                pdiext::SetFrameModeLetterBox(false);
                context.getUpdateContext().zoom_for_SD = false;
            }

            else
            {
                ORG.pauseAvailable = false;
                ORG.pauseRace = false;
            }
        }

        context.pushEvent(main::menu::MFunctionEvent(initialize_messenger, context));

        if (Foot.visible)
        {
            if (gSequenceCondition.enable_director_command && !gSequenceCondition.is_buffer_replay_mode)
            {
                ROOT.setFocus(Foot::BSpec::Director);
                ORG.callDriversViewChange();
            }

            else
            {
                ROOT.setFocus(Foot::Exit);
            }
        }

        if (gSequenceCondition.is_buffer_replay_mode && gSequenceCondition.disable_replay_menu)
            OnboardMeterRoot.visible = false;

        if (main::GAME_STATUS.defined("branch"))
        {
            if (main::GAME_STATUS.branch.defined("camera_type"))
            {
                if (main::GAME_STATUS.branch.camera_type == main::gtengine::CameraType::WORLD_MOTION)
                    main::ORG.setWorldCameraMotion(main::GAME_STATUS.branch.mov_world_camera_ebc);

                if (main::GAME_STATUS.branch.camera_type == main::gtengine::CameraType::CAR_MOTION)
                    main::ORG.setCarCameraMotion(main::GAME_STATUS.branch.mov_car_camera_ebc);    
            }
        }
        
        if (GAME_STATUS.user_profile.option.bot)
            BotUtil::begin(context);
    }

    function initialize_messenger(context)
    {
        UIKitProject::MessengerRoot.open(context, 0x20, 0x20E, 0x1BC, 0x192);
        UIKitProject::MessengerRoot.enterPopupMode(context);
    }

    method on_failed_to_start_session(context)
    {
        ROOT.visible = true;
        OnboardMeterRoot.visible = true;
        ORG.enableRenderingRace();
        ORG.enableSoundingRace();
        ORG.getRaceSound().start = true;
        main::ORG.pauseHandleAvailable = false;

        DialogUtil::openConfirmDialog(context, DialogUtil::ERROR, 
        context.translate(ROOT, "OnlineMessage", "DISCONNECTED"));

        main::ORG.pauseRace = false;
        goToMenuSequence(context);
    }

    method onFinalize(context)
    {
        if (GAME_STATUS.user_profile.option.bot)
            BotUtil::end();

        if (main::GAME_STATUS.defined("branch"))
        {
            if (main::GAME_STATUS.branch.defined("camera_type"))
            {
                if (main::GAME_STATUS.branch.camera_type == main::gtengine::CameraType::WORLD_MOTION)
                    ORG.clearWorldCameraMotion();

                if (main::GAME_STATUS.branch.camera_type == main::gtengine::CameraType::CAR_MOTION)
                    ORG.clearCarCameraMotion();    
            }
        }
        
        if (PluginModule.defined("onRaceRootFinalize"))
            PluginModule::onRaceRootFinalize(context);

        ORG.disableRenderingRace();
        ORG.disableSoundingRace();
        LeaveDetectUtil::end(context);
        self.BalloonTip.reset_value(context);
        self.BalloonTip.visible = false;
        
        DialogUtil::cancelConfirmDialog(context);
        RacerSelectPopup.abort(context);
        Foot.finalize(context);

        if (!context.getUpdateContext().zoom_for_SD)
        {
            pdiext::SetFrameModeLetterBox(true);
            context.getUpdateContext().zoom_for_SD = true;
        }

        self.removePauseMenu(context);
        main::ORG.clearEventCallback();
        SoundUtil::SetupSound(SoundUtil::SCENE_MENU);
        CursorProject::GTLogoTransition.setMarkVisible(true);
        main::pdistd::MGamePort::SetWheelAssignMode(main::pdistd::WheelAssignMode::SDK);
        UIKitProject::MessengerRoot.close(context);

        if (sViewChangeWatcher != nil)
        {
            WatcherUtil::Delete(sViewChangeWatcher);
            sViewChangeWatcher = nil;
        }
    }

    method onCancel(context)
    {
        if (RaceMenuUtil::activated() && gSequenceCondition.isASpecPlaying())
        {
            main::sound.play("cancel");
            RaceMenuUtil::setFocus(context, 0);
            closePauseMenu(context);
        }

        else
        {
            if (!gSequenceCondition.disable_replay_menu)
            {
                main::sound.play("cancel");
                ROOT.setFocus(Foot::Exit);
            }
        }

        return EVENTRESULT_FILTER;
    }

    method onKeyPress(context, event)
    {
        if (isPhotoPreview)
        {
            if (event.keysym == CELL_PAD_CTRL_CROSS)
            {
                main::sound.play("next");
                savePhotoFile(context);
                backFromPreivew(context);
                isPhotoPreview = false;
            }

            else if (event.keysym == CELL_PAD_CTRL_CIRCLE)
            {
                main::sound.play("cancel");
                backFromPreivew(context);
                isPhotoPreview = false;
            }

            return EVENTRESULT_FILTER;
        }

        if (gSequenceCondition.isASpecPlaying())
        {
            if (RaceMenuUtil::activated())
                return EVENTRESULT_CONTINUE;

            else
                return EVENTRESULT_FILTER;    
        }

        else
        {
            if (ROOT.sEnablePhoto && context.active_root_transition == nil && event.keysym == CELL_PAD_CTRL_START)
            {
                main::sound.play("checkbox");

                if (ORG.pauseRace)
                    set_dt(1.0);

                else
                    set_dt(0.0);
                    
                changePauseState(context);    
            }

            if (LeaveDetectUtil::activated(context, event))
                return EVENTRESULT_FILTER;

            if (gSequenceCondition.isDemo() && gSequenceCondition.disable_replay_menu)
            {
                var keyState = context.getUpdateContext().getPadButtonState(0);

                if (!ORG.isDebugStopFlag() && !(keyState & 0x1000) && event.keysym == CELL_PAD_CTRL_START)
                {
                    OnboardMeterRoot.visible = false;
                    self.quit(context);
                    return EVENTRESULT_FILTER;
                }
            }
            
            if (!gSequenceCondition.disable_replay_menu && event.keysym == CELL_PAD_CTRL_SELECT)
            {
                if (ORG.pauseRace || ORG.isTargetCaPitIn())
                {
                    main::sound.play("disable");
                    return EVENTRESULT_FILTER;
                }

                main::sound.play("cursor");
                ORG.callDriversViewChange();
                return EVENTRESULT_FILTER;
            }

            if (FullViewRoot.isActive())
                FullViewRoot.onKeyPress(context, event);

            if (LiveTimingRoot.isActive())
                LiveTimingRoot.onKeyPress(context, event);
                
            var is_ta = RaceOperator.race_parameter.race_type == main::gtengine::GameMode::TIME_ATTACK;
            
            if (is_ta && __projects__["RaceTimeAttackProject"] != nil && gSequenceCondition.is_logger_mode)
            {
                if (RaceTimeAttackProject::DataLoggerRoot.isActive())
                    RaceTimeAttackProject::DataLoggerRoot.onKeyPress(context, event);

                if ((event.state & 0x200) != 0)
                    return EVENTRESULT_FILTER;   
            }

            return EVENTRESULT_CONTINUE;
        }
    }

    method process_after_session(context)
    {
        if (PluginModule.defined("onAfterSession"))
            PluginModule::onAfterSession(context);

        writebackParameter();
        checkTrophyAfterRace(ROOT.sLastConditionSatisfied);    
    }

    method quit(context, result_entry_list)
    {
        if (self.sAlreadyQuited)
            return;

        else
            self.sAlreadyQuited = true;
            
        main::ORG.clearEventCallback();
        SoundUtil::BGMFadeout(1.0);
        main::ORG.getRaceSound().start = false;
        
        context.root_transition = menu::MRootTransition(CursorProject::ColorTransition);
        context.root_transition.pageOut(context);
        context.root_transition.start();
        context.syncOutRootTransition();

        if (ROOT::Foot.current_view != nil)
            ROOT::Foot.current_view.finalize(context);

        if (!gSequenceCondition.disable_end_session)
        {
            main::ORG.endSession();
            self.process_after_session(context);
        }
        
        if (PluginModule.defined("onQuitRace"))
            PluginModule::onQuitRace(context);

        main::ORG.pauseRace = true;
        context.wait(0.1);
        var is_ta = RaceOperator.race_parameter.race_type == gtengine::GameMode::TIME_ATTACK;
        
        if (is_ta && gSequenceCondition.is_buffer_replay_mode && gSequenceCondition.is_logger_mode)
        {
            var datalogger = main::gtengine::MDataLogger();
            datalogger.resetRaceControl();
            datalogger.endLoggerData();
        }

        if (PluginModule.defined("onAfterRace"))
            PluginModule::onAfterRace(context);

        main::ORG.pauseRace = false;
        
        if (PluginModule.defined("onGoToNextSequence"))
        {
            PluginModule::onGoToNextSequence(context);
        }

        else
        {
            if (gSequenceCondition.quick_root != nil)
            {
                gSequenceCondition.quick_root.open(context);
            }

            else
            {
                goToMenuSequence(context);
            }
        }
    }

    method quit_and_goto_top(context, result_entry_list)
    {
        if (self.sAlreadyQuited)
            return;

        else
            self.sAlreadyQuited = true;
            
        main::ORG.clearEventCallback();
        SoundUtil::BGMFadeout(1.0);
        main::ORG.getRaceSound().start = false;
        
        if (!gSequenceCondition.disable_end_session)
        {
            main::ORG.endSession();
            self.process_after_session(context);
        }

        if (PluginModule.defined("onQuitRace"))
            PluginModule::onQuitRace(context);

        main::ORG.pauseRace = true;
        context.wait(0.1);
        
        if (PluginModule.defined("onAfterRace"))
            PluginModule::onAfterRace(context);

        main::ORG.pauseRace = false;
        goToMenuSequence(context);    
    }

    method activatePauseMenu(context)
    {
        RaceMenuUtil::resetCloseAction(context);
        RaceMenuUtil::setFocus(context, 0);
        context.cursor_visible = true;
        RaceMenuUtil::appearAction();
    }

    method deactivatePauseMenu(context)
    {
        context.cursor_visible = false;
        RaceMenuUtil::hideAction();
        resetFocus(ROOT);
    }

    method activateFoot(context)
    {
        context.cursor_visible = true;
        Foot::ScalarInterpolator.reverse = false;
        Foot::ScalarInterpolator.start();
        Head::ScalarInterpolator.reverse = false;
        Head::ScalarInterpolator.start();

        if (Foot.current_view != nil && LTBase["View"] != nil && Foot.current_view.View.defined("activateMenu"))
        {
            LTBase.View.activateMenu(context);
        }

        ORG.disp_meter = false;
    }

    method deactivateFoot(context, warp)
    {
        if (!(gSequenceCondition.enable_director_command && !gSequenceCondition.is_buffer_replay_mode))
        {
            context.cursor_visible = false;
            Foot::ScalarInterpolator.reverse = true;

            if (warp != nil && warp)
                Foot::ScalarInterpolator.warp();

            else
                Foot::ScalarInterpolator.start();
                
            Head::ScalarInterpolator.reverse = true;
            
            if (warp != nil && warp)
            {
                Head::ScalarInterpolator.warp();
            }
        }

        else
        {
            Head::ScalarInterpolator.start();
        }

        if (Foot.current_view != nil && LTBase["View"] != nil && Foot.current_view.View.defined("deactivateMenu"))
        {
            LTBase.View.deactivateMenu(context, warp);
        }
    }

    method changePauseState(context, sound = true)
    {
        if (gSequenceCondition.enable_director_command && !gSequenceCondition.is_buffer_replay_mode)
            return;

        context.sync(0.1);
        var pause = main::ORG.pauseRace;
        
        if (!pause)
        {
            disappearPhoto(context);

            if (LeaveDetectUtil::isSuspend())
                LeaveDetectUtil::resume(context);
        }

        else
        {
            appearPhoto(context);

            if (!LeaveDetectUtil::isSuspend())
                LeaveDetectUtil::suspend(context);
        }

        if (sound)
        {
            SoundUtil::BGMPause(pause);
            SoundUtil::PauseStream(pause);
        }
    }

    method appearPhoto(context)
    {
        main::ORG.getRaceSound().start = false;

        Foot::PauseAndPhoto.active = true;
        Foot::PauseAndPhoto::label.visible = false;
        Foot::PauseAndPhoto::label_only_pause.visible = false;
        Foot::PauseAndPhoto::label_exit.visible = true;

        sPrevIsPitIn = false;
        var disable_photo = false;

        if (ORG.isTargetCaPitIn())
        {
            sPrevIsPitIn = true;
            var camnum = ORG.getTargetCarDistributeCameraNum();

            if (camnum <= 0)
                var disable_photo = true;
        }

        if (!Foot::Button::ViewFull.active || disable_photo)
        {
            Foot::PhotoButton::HBox::Photo.insensitive = true;
            Foot::PhotoButton::HBox::EasyPhoto.insensitive = true;
            Foot::PhotoButton::HBox::Photo::ScalarInterpolator.reverse = true;
            Foot::PhotoButton::HBox::Photo::ScalarInterpolator.start();
            Foot::PhotoButton::HBox::EasyPhoto::ScalarInterpolator.reverse = true;
            Foot::PhotoButton::HBox::EasyPhoto::ScalarInterpolator.start();

            return;
        }

        Foot::PhotoButton::HBox::Photo::ScalarInterpolator.reverse = false;
        Foot::PhotoButton::HBox::Photo::ScalarInterpolator.start();
        Foot::PhotoButton::HBox::Photo.insensitive = false;
        Foot::PhotoButton::HBox::EasyPhoto.insensitive = true;
        Foot::PhotoButton::HBox::Photo.visible = true;
        Foot::PhotoButton::HBox::EasyPhoto.visible = false;
    }

    method disappearPhoto(context)
    {
        main::ORG.getRaceSound().start = true;
        Foot::PauseAndPhoto.active = false;

        if (Foot::Button::ViewFull.active)
        {
            Foot::PauseAndPhoto::label.visible = true;
            Foot::PauseAndPhoto::label_only_pause.visible = false;
        }

        else
        {
            Foot::PauseAndPhoto::label.visible = false;
            Foot::PauseAndPhoto::label_only_pause.visible = true;
        }

        Foot::PauseAndPhoto::label_exit.visible = false;
        Foot::PhotoButton::HBox::Photo.insensitive = true;
        Foot::PhotoButton::HBox::EasyPhoto.insensitive = true;
        Foot::PhotoButton::HBox::Photo::ScalarInterpolator.reverse = true;
        Foot::PhotoButton::HBox::Photo::ScalarInterpolator.start();
        Foot::PhotoButton::HBox::EasyPhoto::ScalarInterpolator.reverse = true;
        Foot::PhotoButton::HBox::EasyPhoto::ScalarInterpolator.start();

        if (ROOT.focus_widget == Foot::PhotoButton::HBox::Photo 
        || ROOT.focus_widget == Foot::PhotoButton::HBox::EasyPhoto)
        {
            ROOT.setFocus(Foot::Exit);
        }
    }

    method closePauseMenu(context)
    {
        main::ORG.pauseHandleAvailable = false;
        RaceMenuUtil::closeAction(context);

        Foot::ScalarInterpolator.reverse = true;
        Foot::ScalarInterpolator.start();
        Head::ScalarInterpolator.reverse = true;
        Head::ScalarInterpolator.start();

        main::ORG.pauseRace = false;
        OnboardMeterRoot.appearPanel();
        resetFocus(ROOT);

